      "viewportScrollY": 54
    },
    "var_84bcad39c33a": {
      "type": "variant",
      "label": "Lyrico Settings (Bootstrap)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 7497,
        "y": 0,
        "w": 375,
        "h": 812
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n\n  :root {\n    --lp-cream: #F4E9D0;\n    --lp-cream-2: #EFE0BE;\n    --lp-ink: #3A2C5C;\n    --lp-pumpkin: #E08244;\n    --lp-mint: #A8D6B8;\n    --lp-crimson: #C23D3D;\n  }\n\n  body {\n    background-color: var(--lp-cream);\n    color: var(--lp-ink);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-display { font-family: 'Fraunces', serif; }\n\n  /* Paper Grain Texture */\n  .paper-bg {\n    position: relative;\n    background-color: var(--lp-cream);\n  }\n  .paper-bg::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    background-image: radial-gradient(var(--lp-ink) 1px, transparent 1px);\n    background-size: 24px 24px;\n    opacity: 0.03;\n  }\n\n  /* Hand-cut Imperfect Border (PaperCutShape) */\n  .cut-card {\n    clip-path: polygon(1% 2%, 8% 0%, 22% 3%, 45% 1%, 70% 2%, 88% 0%, 99% 3%, 100% 18%, 98% 40%, 100% 62%, 99% 82%, 100% 97%, 84% 100%, 60% 98%, 36% 100%, 14% 99%, 2% 100%, 0% 80%, 2% 55%, 0% 30%, 1% 12%);\n  }\n\n  /* Washi Tape */\n  .washi {\n    height: 22px;\n    background: linear-gradient(to bottom, var(--color-washi), rgba(0,0,0,0.1));\n    border: 1px dashed rgba(58, 44, 92, 0.1);\n    position: relative;\n  }\n\n  /* Dotted Divider */\n  .dotted {\n    background-image: radial-gradient(circle, var(--lp-ink) 1.5px, transparent 1.5px);\n    background-size: 12px 12px;\n    background-repeat: repeat-x;\n    background-position: center;\n    height: 12px;\n    width: 100%;\n  }\n\n  /* Shadows */\n  .paper-shadow {\n    filter: drop-shadow(0 8px 10px rgba(58, 44, 92, 0.35)) drop-shadow(0 4px 0 rgba(58, 44, 92, 0.1));\n  }\n\n  /* Slider Styling */\n  .slider {\n    -webkit-appearance: none;\n    width: 100%;\n    height: 6px;\n    background: rgba(58, 44, 92, 0.1);\n    border-radius: 5px;\n    outline: none;\n  }\n  .slider::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    appearance: none;\n    width: 18px;\n    height: 18px;\n    background: var(--lp-pumpkin);\n    cursor: pointer;\n    border-radius: 50%;\n    border: 2px solid var(--lp-ink);\n  }\n</style>\n\n<div class=\"paper-bg min-h-screen pb-12\" data-kid=\"1\">\n  \n  <header class=\"pt-12 pb-4 px-6 text-center\" data-kid=\"2\">\n    <h1 class=\"font-display text-[16px] font-black tracking-[2.5px] uppercase\" data-kid=\"3\">CONFIGURE YOUR SETUP</h1>\n  </header>\n\n  \n    \n    <section class=\"space-y-4\" data-kid=\"4\">\n      <h2 class=\"text-[10px] font-black tracking-[2px] opacity-80 uppercase\" data-kid=\"5\">REAL-TIME PREVIEW</h2>\n      \n      <div class=\"relative h-[240px] cut-card overflow-hidden paper-shadow\" style=\"background-color: rgba(168, 214, 184, 0.2);\" data-kid=\"6\">\n        \n        <div class=\"absolute -top-20 -left-20 w-[280px] h-[180px] cut-card bg-[var(--lp-cream-2)] opacity-40 rotate-[5deg]\" data-kid=\"7\"></div>\n        <div class=\"absolute bottom-10 -right-10 w-[200px] h-[120px] cut-card bg-[var(--lp-pumpkin)] opacity-15 rotate-[-10deg]\" data-kid=\"8\"></div>\n\n        \n        <div class=\"absolute inset-0 flex items-center justify-center p-8\" data-kid=\"9\">\n          <div class=\"w-[310px] h-[170px] cut-card paper-shadow p-5\" style=\"background-color: var(--lp-cream);\" data-kid=\"10\">\n            <div class=\"flex justify-between items-start mb-3\" data-kid=\"11\">\n              <div data-kid=\"12\">\n                <div class=\"font-display text-[14px] font-black\" data-kid=\"13\">Song Name</div>\n                <div class=\"font-display text-[11px] font-medium italic opacity-70\" data-kid=\"14\">Artist Name</div>\n              </div>\n              <i class=\"ti ti-music text-[14px] font-bold\" data-kid=\"15\"></i>\n            </div>\n            \n            <div class=\"space-y-1\" data-kid=\"16\">\n              <div class=\"text-[14px] opacity-50 px-2\" data-kid=\"17\">...borrowed the moon.</div>\n              <div class=\"relative px-2 py-1\" data-kid=\"18\">\n                <div class=\"absolute inset-0 washi rotate-[-1.2deg]\" style=\"--color-washi: rgba(224, 130, 68, 0.2);\" data-kid=\"19\"></div>\n                <div class=\"relative font-display text-[14px] font-black\" data-kid=\"20\">Tonight, said the rabbit...</div>\n              </div>\n              <div class=\"text-[14px] opacity-50 px-2\" data-kid=\"21\">Just for safe keeping.</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"space-y-4\" data-kid=\"22\">\n      <h2 class=\"text-[10px] font-black tracking-[2px] opacity-80 uppercase\" data-kid=\"23\">QUICK STYLING PRESETS</h2>\n      \n      <div class=\"flex gap-5 overflow-x-auto pb-4 -mx-2 px-2 scrollbar-hide\" data-kid=\"24\">\n        \n        <div class=\"flex-shrink-0 flex flex-col items-center gap-3 p-4 cut-card paper-shadow w-[92px]\" style=\"background-color: rgba(168, 214, 184, 0.25); border: 2px solid var(--lp-ink);\" data-kid=\"25\">\n          <div class=\"relative w-16 h-11 cut-card bg-[var(--lp-cream)] border border-ink/20\" data-kid=\"26\">\n            <div class=\"absolute bottom-2 right-3 w-4 h-4 rounded-full bg-[var(--lp-pumpkin)]\" data-kid=\"27\"></div>\n            <div class=\"absolute top-2 left-2 w-3 h-3 rounded-full bg-[var(--lp-ink)]\" data-kid=\"28\"></div>\n          </div>\n          <span class=\"text-[10px] font-black tracking-widest uppercase\" data-kid=\"29\">CLASSIC</span>\n        </div>\n\n        \n        <div class=\"flex-shrink-0 flex flex-col items-center gap-3 p-4 cut-card paper-shadow w-[92px]\" style=\"background-color: rgba(255, 255, 255, 0.45);\" data-kid=\"30\">\n          <div class=\"relative w-16 h-11 cut-card bg-[var(--lp-mint)] border border-ink/20\" data-kid=\"31\">\n            <div class=\"absolute bottom-2 right-3 w-4 h-4 rounded-full bg-[var(--lp-crimson)]\" data-kid=\"32\"></div>\n            <div class=\"absolute top-2 left-2 w-3 h-3 rounded-full bg-[var(--lp-ink)]\" data-kid=\"33\"></div>\n          </div>\n          <span class=\"text-[10px] font-black tracking-widest uppercase\" data-kid=\"34\">MINT</span>\n        </div>\n\n        \n        <div class=\"flex-shrink-0 flex flex-col items-center gap-3 p-4 cut-card paper-shadow w-[92px]\" style=\"background-color: rgba(255, 255, 255, 0.45);\" data-kid=\"35\">\n          <div class=\"relative w-16 h-11 cut-card bg-[var(--lp-ink)] border border-ink/20\" data-kid=\"36\">\n            <div class=\"absolute bottom-2 right-3 w-4 h-4 rounded-full bg-[var(--lp-pumpkin)]\" data-kid=\"37\"></div>\n            <div class=\"absolute top-2 left-2 w-3 h-3 rounded-full bg-[var(--lp-cream)]\" data-kid=\"38\"></div>\n          </div>\n          <span class=\"text-[10px] font-black tracking-widest uppercase\" data-kid=\"39\">MIDNIGHT</span>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"space-y-4\" data-kid=\"40\">\n      <h2 class=\"text-[10px] font-black tracking-[2px] opacity-80 uppercase\" data-kid=\"41\">MANUAL ADJUSTMENTS</h2>\n      \n      <div class=\"cut-card paper-shadow bg-white/35 p-0 border border-ink/15\" data-kid=\"42\">\n        \n        <div class=\"p-4 flex items-center justify-between border-b border-ink/5\" data-kid=\"43\">\n          <span class=\"font-display text-[16px] font-bold\" data-kid=\"44\">Background</span>\n          <div class=\"flex items-center gap-3\" data-kid=\"45\">\n            <span class=\"text-[13px] font-medium font-mono opacity-90\" data-kid=\"46\">#F4E9D0</span>\n            <div class=\"w-6 h-6 cut-card bg-[var(--lp-cream)] border-[1.5px] border-ink/40\" data-kid=\"47\"></div>\n          </div>\n        </div>\n        <div class=\"p-4 flex items-center justify-between border-b border-ink/5\" data-kid=\"48\">\n          <span class=\"font-display text-[16px] font-bold\" data-kid=\"49\">Context Lines</span>\n          <div class=\"flex items-center gap-3\" data-kid=\"50\">\n            <span class=\"text-[13px] font-medium font-mono opacity-90\" data-kid=\"51\">#3A2C5C</span>\n            <div class=\"w-6 h-6 cut-card bg-[var(--lp-ink)] border-[1.5px] border-ink/40\" data-kid=\"52\"></div>\n          </div>\n        </div>\n        <div class=\"p-4 flex items-center justify-between\" data-kid=\"53\">\n          <span class=\"font-display text-[16px] font-bold\" data-kid=\"54\">Active Highlight</span>\n          <div class=\"flex items-center gap-3\" data-kid=\"55\">\n            <span class=\"text-[13px] font-medium font-mono opacity-90\" data-kid=\"56\">#E08244</span>\n            <div class=\"w-6 h-6 cut-card bg-[var(--lp-pumpkin)] border-[1.5px] border-ink/40\" data-kid=\"57\"></div>\n          </div>\n        </div>\n\n        <div class=\"px-5 py-3\" data-kid=\"58\">\n          <div class=\"dotted opacity-50\" data-kid=\"59\"></div>\n        </div>\n\n        \n        <div class=\"p-5 space-y-3\" data-kid=\"60\">\n          <div class=\"flex justify-between items-center\" data-kid=\"61\">\n            <span class=\"font-display text-[16px] font-bold\" data-kid=\"62\">Text Sizing</span>\n            <span class=\"text-[12px] font-bold font-mono opacity-60\" data-kid=\"63\">16 pt</span>\n          </div>\n          <input type=\"range\" min=\"12\" max=\"22\" value=\"16\" class=\"slider\" data-kid=\"64\">\n        </div>\n\n        \n        <div class=\"p-5 pt-0 flex justify-between items-center\" data-kid=\"65\">\n          <span class=\"font-display text-[16px] font-bold\" data-kid=\"66\">Line Capacity</span>\n          <div class=\"text-[14px] text-[var(--lp-crimson)] font-bold\" data-kid=\"67\">3 Lines <i class=\"ti ti-chevron-down ml-1\" data-kid=\"68\"></i></div>\n        </div>\n      </div>\n    </section>\n\n    \n    \n      <div class=\"relative px-6 py-3 washi rotate-[-0.5deg] paper-shadow flex items-center gap-2\" style=\"--color-washi: var(--lp-cream-2);\" data-kid=\"69\">\n        <i class=\"ti ti-circle-check-filled text-[18px] text-[var(--lp-mint)]\" data-kid=\"70\"></i>\n        <span class=\"font-display text-[12px] font-black tracking-[1px] text-[var(--lp-mint)]\" data-kid=\"71\">SHARED STORAGE ACTIVE</span>\n      </div>\n\n      <div class=\"text-center opacity-40 space-y-1\" data-kid=\"72\">\n        <div class=\"text-[10px] font-black tracking-[1px]\" data-kid=\"73\">LYRICO v1.0</div>\n        <div class=\"font-display text-[10px] font-light italic\" data-kid=\"74\">picture books for the home screen</div>\n      </div>\n    \n\n\n\n<nav class=\"fixed bottom-0 left-0 right-0 bg-white/80 backdrop-blur-md border-t border-ink/10 flex justify-around py-3 px-8\" data-kid=\"75\">\n  <div class=\"flex flex-col items-center opacity-40\" data-kid=\"76\">\n    <i class=\"ti ti-search text-[24px]\" data-kid=\"77\"></i>\n    <span class=\"text-[10px] font-bold mt-1\" data-kid=\"78\">Search</span>\n  </div>\n  <div class=\"flex flex-col items-center text-[var(--lp-crimson)]\" data-kid=\"79\">\n    <i class=\"ti ti-settings text-[24px]\" data-kid=\"80\"></i>\n    <span class=\"text-[10px] font-bold mt-1\" data-kid=\"81\">Settings</span>\n  </div>\n</nav>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css\" data-kid=\"82\"></div>",
