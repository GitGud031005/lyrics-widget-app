      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --cream: #F4E9D0;\n    --cream-2: #EFE0BE;\n    --ink: #3A2C5C;\n    --pumpkin: #E08244;\n    --mint: #A8D6B8;\n    --crimson: #C23D3D;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background-color: #e5e7eb;\n    font-family: 'Inter', sans-serif;\n  }\n\n  .font-display { font-family: 'Fraunces', serif; }\n  .font-body { font-family: 'Inter', sans-serif; }\n\n  .paper-bg {\n    background-color: var(--cream);\n    background-image:\n      radial-gradient(rgba(58,44,92,0.06) 1px, transparent 1px),\n      radial-gradient(rgba(192,140,80,0.08) 1.5px, transparent 1.5px);\n    background-size: 24px 24px, 12px 12px;\n    background-position: 0 0, 4px 4px;\n    position: relative;\n  }\n\n  .paper-bg::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0.35;\n    mix-blend-mode: multiply;\n    background-image: url(\"data:image/svg+xml;utf8,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='noise'><feTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23noise)'/></svg>\");\n  }\n\n  .paper-shadow {\n    filter: drop-shadow(0 15px 15px rgba(58,44,92,0.25)) drop-shadow(0 4px 0 rgba(58,44,92,0.1));\n  }\n\n  /* hand-cut imperfect borders via clip-path */\n  .cut-widget {\n    clip-path: polygon(\n      0.5% 1.5%, 15% 0.5%, 35% 2%, 55% 0%, 75% 1.5%, 92% 0%, 99% 2%, \n      100% 15%, 98.5% 35%, 100% 55%, 99% 75%, 100% 92%, 99.5% 98.5%,\n      85% 99.5%, 65% 98%, 45% 100%, 25% 99%, 8% 100%, 0.5% 98%,\n      0% 85%, 1.5% 65%, 0% 45%, 1% 25%, 0% 8%\n    );\n  }\n\n  .crease-line {\n    position: absolute;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: repeating-linear-gradient(to right, rgba(58,44,92,.15) 0 8px, transparent 8px 16px);\n  }\n\n  .active-lyric-box {\n    position: relative;\n    background: var(--cream-2);\n    box-shadow: inset 0 3px 6px rgba(58,44,92,0.08);\n    border-top: 1px solid rgba(58,44,92,0.12);\n    border-bottom: 1px solid rgba(58,44,92,0.12);\n  }\n\n  .active-lyric-box::after {\n    content: \"\";\n    position: absolute;\n    left: 12px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 3px;\n    height: 60%;\n    background: var(--pumpkin);\n    border-radius: 4px;\n  }\n\n  .btn-tab {\n    position: relative;\n    background: var(--cream-2);\n    border: 1.5px solid var(--ink);\n    border-radius: 12px 14px 10px 12px;\n    box-shadow: 0 4px 0 var(--ink);\n  }\n\n  .btn-tab:active {\n    transform: translateY(2px);\n    box-shadow: 0 2px 0 var(--ink);\n  }\n\n  .btn-tab-primary {\n    background: var(--crimson);\n    color: var(--cream);\n    box-shadow: 0 4px 0 var(--ink);\n  }\n\n  .star-deco {\n    color: var(--pumpkin);\n    filter: drop-shadow(0 1px 1px rgba(0,0,0,0.15));\n  }\n\n  .paper-fold {\n    position: absolute;\n    bottom: -15px;\n    right: -15px;\n    width: 45px;\n    height: 45px;\n    background: var(--cream-2);\n    box-shadow: -2px -2px 5px rgba(58,44,92,0.1);\n    transform: rotate(45deg);\n    border-left: 1px solid rgba(58,44,92,0.1);\n    z-index: 5;\n  }\n\n  .scrolling-content {\n    mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);\n  }\n\n</style>\n\n<div class=\"w-[322px] h-[324px] paper-bg cut-widget paper-shadow p-5 flex flex-col justify-between overflow-hidden relative\" data-kid=\"1\">\n  \n  <div class=\"crease-line top-[15%] opacity-30\" data-kid=\"2\"></div>\n  <div class=\"crease-line bottom-[28%] opacity-30\" data-kid=\"3\"></div>\n  <div class=\"absolute left-1/2 top-0 bottom-0 w-[1px] bg-[var(--ink)]/5 opacity-50\" data-kid=\"4\"></div>\n\n  \n  <div class=\"relative z-10 flex items-start justify-between\" data-kid=\"5\">\n    <div class=\"flex-1\" data-kid=\"6\">\n      <div class=\"flex items-center gap-1.5 mb-1.5\" data-kid=\"7\">\n        <span class=\"text-[10px] font-bold tracking-[0.18em] uppercase text-[var(--ink)] opacity-50 font-body\" data-kid=\"8\">Lamplight Archives</span>\n        <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--crimson)] opacity-80\" data-kid=\"9\"></div>\n      </div>\n      <h1 class=\"font-display text-[21px] font-black text-[var(--ink)] leading-[1.1] tracking-tight pr-4\" data-kid=\"10\">\n        The Rabbit Who Borrowed the Moon\n      </h1>\n      <p class=\"font-display italic text-sm text-[var(--ink)]/70 mt-1 flex items-center gap-1.5\" data-kid=\"11\">\n        <span class=\"opacity-40 font-body not-italic text-[10px] tracking-widest\" data-kid=\"12\">—</span> \n        Imogen Pell\n      </p>\n    </div>\n    <div class=\"star-deco flex shrink-0 mt-1\" data-kid=\"13\">\n      <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"14\">\n        <path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\" data-kid=\"15\"></path>\n        <circle cx=\"12\" cy=\"12\" r=\"2\" fill=\"currentColor\" data-kid=\"16\"></circle>\n      </svg>\n    </div>\n  </div>\n\n  \n  <div class=\"relative z-10 flex-1 my-2 flex flex-col justify-center overflow-hidden scrolling-content\" data-kid=\"17\">\n    <div class=\"space-y-4 py-1\" data-kid=\"18\">\n      \n      <p class=\"text-[var(--ink)] opacity-40 text-[11px] font-medium text-center font-display italic leading-tight\" data-kid=\"19\">\n        Lifting his watch with a trembling hand\n      </p>\n      \n      \n      <p class=\"text-[var(--ink)] opacity-60 text-[12px] font-medium text-center font-display italic leading-tight\" data-kid=\"20\">\n        He whispered to stars in the velvet sky\n      </p>\n\n      \n      <div class=\"active-lyric-box py-3.5 px-6 mx-[-20px]\" data-kid=\"21\">\n        <p class=\"text-[var(--ink)] text-[15px] font-bold text-center leading-snug font-display\" data-kid=\"22\">\n          \"Tonight,\" said the rabbit, \"the moon will be here.\"\n        </p>\n      </div>\n\n      \n      <p class=\"text-[var(--ink)] opacity-60 text-[12px] font-medium text-center font-display italic leading-tight\" data-kid=\"23\">\n        Just for safe keeping, until morning light\n      </p>\n\n      \n      <p class=\"text-[var(--ink)] opacity-40 text-[11px] font-medium text-center font-display italic leading-tight\" data-kid=\"24\">\n        When the sun trades its gold for the silver of night\n      </p>\n    </div>\n  </div>\n\n  \n  <div class=\"relative z-10 grid grid-cols-3 gap-3.5 h-[62px] mb-1\" data-kid=\"25\">\n    <button class=\"btn-tab flex flex-col items-center justify-center group\" data-kid=\"26\">\n      <i class=\"ti ti-player-skip-back text-lg text-[var(--ink)] mb-0.5\" data-kid=\"27\"></i>\n      <span class=\"text-[10px] font-black uppercase tracking-tight text-[var(--ink)] opacity-60\" data-kid=\"28\">Back</span>\n    </button>\n    \n    <button class=\"btn-tab btn-tab-primary flex flex-col items-center justify-center group\" data-kid=\"29\">\n      <i class=\"ti ti-refresh text-lg mb-0.5\" data-kid=\"30\"></i>\n      <span class=\"text-[10px] font-black uppercase tracking-tight text-[var(--cream)] opacity-80\" data-kid=\"31\">Reset</span>\n    </button>\n    \n    <button class=\"btn-tab flex flex-col items-center justify-center group\" data-kid=\"32\">\n      <i class=\"ti ti-player-skip-forward text-lg text-[var(--ink)] mb-0.5\" data-kid=\"33\"></i>\n      <span class=\"text-[10px] font-black uppercase tracking-tight text-[var(--ink)] opacity-60\" data-kid=\"34\">Next</span>\n    </button>\n  </div>\n\n  \n  <div class=\"paper-fold pointer-events-none\" data-kid=\"35\"></div>\n  <div class=\"absolute bottom-1.5 right-1.5 opacity-10 pointer-events-none z-10\" data-kid=\"36\">\n    <svg width=\"32\" height=\"32\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"37\">\n      <path d=\"M0 40C20 40 40 20 40 0V40H0Z\" fill=\"var(--ink)\" data-kid=\"38\"></path>\n    </svg>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"39\"></script>\n<script data-kid=\"40\">\n  // Subtle entrance animation for the canvas preview\n  window.onload = () => {\n    gsap.from(\".cut-widget\", {\n      scale: 0.95,\n      opacity: 0,\n      rotate: -1,\n      duration: 1,\n      ease: \"elastic.out(1, 0.75)\"\n    });\n\n    gsap.from(\".active-lyric-box p\", {\n      y: 10,\n      opacity: 0,\n      duration: 0.8,\n      delay: 0.4,\n      ease: \"power2.out\"\n    });\n\n    gsap.from(\".btn-tab\", {\n      y: 20,\n      opacity: 0,\n      duration: 0.6,\n      stagger: 0.1,\n      delay: 0.6,\n      ease: \"back.out(1.7)\"\n    });\n  };\n</script>\n",
