-ink)] bg-[var(--cream)] rounded-full placeholder:text-[var(--ink)]/50 outline-hidden focus:bg-white\" data-kid=\"387\">\n            <button class=\"btn-crimson px-5 py-3 font-semibold flex items-center gap-2\" data-kid=\"388\">\n              <i class=\"ti ti-feather text-lg\" data-kid=\"389\"></i> Sign\n            </button>\n          </form>\n          <div class=\"mt-4 flex items-center gap-2 text-xs opacity-70\" data-kid=\"390\"><i class=\"ti ti-lock text-base\" data-kid=\"391\"></i> 12,400 readers · unsubscribe with a single fold.</div>\n        </div>\n        <div class=\"col-span-5 relative\" data-kid=\"392\">\n          <div class=\"relative w-full aspect-[3/4] border-[3px] border-[var(--ink)] overflow-hidden pop-shadow rotate-[3deg]\" style=\"clip-path: polygon(4% 3%, 50% 0, 96% 4%, 100% 50%, 97% 96%, 50% 100%, 4% 96%, 0 50%);\" data-kid=\"393\">\n            <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/a993fd29-0101-46bc-9b8b-13bc576c1070/98af5e4f49344c06ae10455cab032214.png\" class=\"w-full h-full object-cover\" alt decoding=\"async\" loading=\"lazy\" data-kid=\"394\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n          </div>\n          <div class=\"absolute -bottom-3 -left-3 px-4 py-2 bg-[var(--crimson)] text-[var(--cream)] border-2 border-[var(--ink)] font-display italic-d rotate-[-5deg]\" data-kid=\"395\">issue 47</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"relative paper-ink text-[var(--cream)] pt-20 pb-10 px-8 mt-2\" data-kid=\"396\">\n  <div class=\"absolute -top-5 left-0 right-0 h-5 paper-ink scallop-top\" data-kid=\"397\"></div>\n  <div class=\"absolute inset-0 grain opacity-40\" data-kid=\"398\"></div>\n  <div class=\"max-w-[1280px] mx-auto relative\" data-kid=\"399\">\n\n    <div class=\"grid grid-cols-12 gap-10 pb-12\" data-kid=\"400\">\n      <div class=\"col-span-4\" data-kid=\"401\">\n        <div class=\"flex items-center gap-3 mb-5\" data-kid=\"402\">\n          <div class=\"w-12 h-12 rounded-full bg-[var(--cream)] flex items-center justify-center\" data-kid=\"403\">\n            <span class=\"font-display text-2xl italic font-bold text-[var(--ink)]\" data-kid=\"404\">F</span>\n          </div>\n          <div class=\"font-display text-2xl font-bold\" data-kid=\"405\">Foxglove &amp; Folio</div>\n        </div>\n        <p class=\"font-display italic text-lg leading-snug text-[var(--cream)]/80 max-w-xs\" data-kid=\"406\">\n          An independent house publishing dreamlike picture books from a Brooklyn loft &amp; a Marseille attic.\n        </p>\n        <div class=\"mt-6 flex items-center gap-3\" data-kid=\"407\">\n          <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" data-kid=\"408\"><i class=\"ti ti-brand-instagram\" data-kid=\"409\"></i></a>\n          <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" data-kid=\"410\"><i class=\"ti ti-brand-x\" data-kid=\"411\"></i></a>\n          <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" data-kid=\"412\"><i class=\"ti ti-brand-pinterest\" data-kid=\"413\"></i></a>\n          <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" data-kid=\"414\"><i class=\"ti ti-rss\" data-kid=\"415\"></i></a>\n        </div>\n      </div>\n\n      <div class=\"col-span-2\" data-kid=\"416\">\n        <div class=\"text-[11px] tracking-[.3em] uppercase opacity-70 mb-4\" data-kid=\"417\">Read</div>\n        <ul class=\"space-y-2 text-sm\" data-kid=\"418\">\n          <li data-kid=\"419\"><a href=\"#\" data-kid=\"420\">Catalogue</a></li>\n          <li data-kid=\"421\"><a href=\"#\" data-kid=\"422\">New &amp; Forthcoming</a></li>\n          <li data-kid=\"423\"><a href=\"#\" data-kid=\"424\">The Folio Letter</a></li>\n          <li data-kid=\"425\"><a href=\"#\" data-kid=\"426\">Backlist</a></li>\n          <li data-kid=\"427\"><a href=\"#\" data-kid=\"428\">Foreign rights</a></li>\n        </ul>\n      </div>\n      <div class=\"col-span-2\" data-kid=\"429\">\n        <div class=\"text-[11px] tracking-[.3em] uppercase opacity-70 mb-4\" data-kid=\"430\">Visit</div>\n        <ul class=\"space-y-2 text-sm\" data-kid=\"431\">\n          <li data-kid=\"432\"><a href=\"#\" data-kid=\"433\">The Workshop</a></li>\n          <li data-kid=\"434\"><a href=\"#\" data-kid=\"435\">Events</a></li>\n          <li data-kid=\"436\"><a href=\"#\" data-kid=\"437\">School visits</a></li>\n          <li data-kid=\"438\"><a href=\"#\" data-kid=\"439\">Press</a></li>\n          <li data-kid=\"440\"><a href=\"#\" data-kid=\"441\">Stockists</a></li>\n        </ul>\n      </div>\n      <div class=\"col-span-4\" data-kid=\"442\">\n        <div class=\"text-[11px] tracking-[.3em] uppercase opacity-70 mb-4\" data-kid=\"443\">Send a letter</div>\n        <div class=\"font-display italic text-xl leading-snug\" data-kid=\"444\">\n          218 Pearl St., Brooklyn, NY 11201<br data-kid=\"445\">\n          17 rue des Trois Lunes, Marseille\n        </div>\n        <div class=\"mt-4 text-sm opacity-80\" data-kid=\"446\">hello@foxglovefolio.press · +1 718 555 0142</div>\n      </div>\n    </div>\n\n    <div class=\"dotted\" style=\"background-image: radial-gradient(circle, var(--cream) 1.5px, transparent 1.5px);\" data-kid=\"447\"></div>\n\n    <div class=\"flex flex-col items-center text-center mt-10 gap-4\" data-kid=\"448\">\n      <div class=\"w-14 h-14 rounded-full bg-[var(--cream)] flex items-center justify-center\" data-kid=\"449\">\n        <span class=\"font-display text-3xl italic font-bold text-[var(--ink)]\" data-kid=\"450\">F</span>\n      </div>\n      <nav class=\"flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm\" data-kid=\"451\">\n        <a href=\"#\" data-kid=\"452\">Home</a><a href=\"#\" data-kid=\"453\">Spreads</a><a href=\"#\" data-kid=\"454\">Library</a><a href=\"#\" data-kid=\"455\">Authors</a><a href=\"#\" data-kid=\"456\">Workshops</a><a href=\"#\" data-kid=\"457\">Shop</a><a href=\"#\" data-kid=\"458\">Contact</a>\n      </nav>\n      <div class=\"text-xs opacity-60 mt-3 font-display italic\" data-kid=\"459\">\n        © 2025 Foxglove &amp; Folio Editions. Every book printed on FSC paper, bound in Belgium, dreamt up nearly anywhere.\n      </div>\n    </div>\n  </div>\n</footer>\n\n\n<div class=\"fixed bottom-8 right-8 z-50\" data-kid=\"460\">\n  <button class=\"satchel w-20 h-20 flex items-center justify-center relative\" data-kid=\"461\">\n    <div class=\"satchel-flap\" data-kid=\"462\"></div>\n    <i class=\"ti ti-shopping-bag text-3xl text-[var(--ink)] relative z-10\" data-kid=\"463\"></i>\n    <span class=\"absolute -top-1 -right-1 w-7 h-7 rounded-full bg-[var(--crimson)] border-2 border-[var(--ink)] text-[var(--cream)] font-display font-bold text-sm flex items-center justify-center\" data-kid=\"464\">3</span>\n  </button>\n  <div class=\"absolute -top-3 -left-3 w-6 h-6 text-[var(--pumpkin)]\" data-kid=\"465\">\n    <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" data-kid=\"466\"><path d=\"M12 2l2.4 7.4H22l-6.2 4.5L18.2 22 12 17.5 5.8 22l2.4-8.1L2 9.4h7.6z\" data-kid=\"467\"></path></svg>\n  </div>\n</div>\n\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"468\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"469\"></script>\n<script data-kid=\"470\">\n  gsap.registerPlugin(ScrollTrigger);\n  const paperEase = \"elastic.out(1, 0.6)\";\n  gsap.utils.toArray('.pop-up').forEach(el=>{\n    gsap.from(el, { scale: 0.4, y: 60, rotate: -6, opacity: 0, duration: 1.2, ease: paperEase,\n      scrollTrigger: { trigger: el, start: 'top 85%' }});\n  });\n  gsap.utils.toArray('.flap-card').forEach((el,i)=>{\n    gsap.from(el, { y: 40, opacity: 0, rotateX: -40, transformOrigin: 'top center', duration: 0.8,\n      ease: 'back.out(1.6)', delay: i*0.05,\n      scrollTrigger: { trigger: el, start: 'top 90%' }});\n  });\n  gsap.utils.toArray('.spine-book').forEach((el,i)=>{\n    gsap.from(el, { y: 80, opacity:0, duration: 0.6, delay: i*0.04, ease:'power3.out',\n      scrollTrigger: { trigger: el, start: 'top 95%'}});\n  });\n  gsap.utils.toArray('.bubble').forEach(el=>{\n    gsap.from(el, { scale: 0.6, opacity:0, duration: 0.7, ease: 'back.out(2)',\n      scrollTrigger: { trigger: el, start: 'top 88%' }});\n  });\n</script>\n  ",
