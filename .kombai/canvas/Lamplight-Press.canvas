    "node_paste_2eab64b25f3f": {
      "type": "variant",
      "id": "node_paste_2eab64b25f3f",
      "label": "Lamplight Press",
      "html": "\n    <style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root{\n  --cream:#F4E9D0;\n  --cream-2:#EFE0BE;\n  --ink:#3A2C5C;\n  --pumpkin:#E08244;\n  --mint:#A8D6B8;\n  --crimson:#C23D3D;\n}\nbody, .font-body{font-family:'Inter',sans-serif;}\n.font-display{font-family:'Fraunces',serif; font-optical-sizing:auto;}\n.italic-d{font-family:'Fraunces',serif; font-style:italic;}\n\n/* paper textures */\n.paper{\n  background-color:var(--cream);\n  background-image:\n    radial-gradient(rgba(58,44,92,0.06) 1px, transparent 1px),\n    radial-gradient(rgba(192,140,80,0.08) 1px, transparent 1px);\n  background-size: 22px 22px, 7px 7px;\n  background-position: 0 0, 3px 3px;\n}\n.paper-mint{\n  background-color:var(--mint);\n  background-image: radial-gradient(rgba(58,44,92,0.07) 1px, transparent 1px);\n  background-size: 14px 14px;\n}\n.paper-ink{background-color:var(--ink);}\n.grain::before{\n  content:\"\"; position:absolute; inset:0; pointer-events:none; opacity:.35; mix-blend-mode:multiply;\n  background-image:url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/></filter><rect width='100%' height='100%' filter='url(%23n)' opacity='0.35'/></svg>\");\n}\n\n/* hand-cut imperfect borders via clip-path */\n.cut-card{\n  clip-path: polygon(1% 2%, 8% 0%, 22% 3%, 45% 1%, 70% 2%, 88% 0%, 99% 3%, 100% 18%, 98% 40%, 100% 62%, 99% 82%, 100% 97%, 84% 100%, 60% 98%, 36% 100%, 14% 99%, 2% 100%, 0% 80%, 2% 55%, 0% 30%, 1% 12%);\n}\n.cut-wave{\n  --m: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 40' preserveAspectRatio='none'><path d='M0,30 C50,5 90,40 140,20 C200,0 240,35 300,18 C360,2 410,38 470,22 C530,8 590,38 650,20 C720,0 770,38 830,22 C900,4 950,38 1010,20 C1070,4 1130,38 1200,18 L1200,40 L0,40 Z' fill='black'/></svg>\");\n  -webkit-mask-image: var(--m); mask-image: var(--m);\n  -webkit-mask-size: 100% 100%; mask-size:100% 100%;\n  -webkit-mask-repeat:no-repeat; mask-repeat:no-repeat;\n}\n.torn-bottom{ position:relative; }\n.torn-bottom::after{\n  content:\"\"; position:absolute; left:0; right:0; bottom:-1px; height:22px;\n  background:inherit;\n  -webkit-mask-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 24' preserveAspectRatio='none'><path d='M0,0 L1200,0 L1200,8 C1140,22 1080,2 1020,14 C960,24 900,6 840,16 C780,24 720,4 660,14 C600,22 540,6 480,16 C420,24 360,4 300,14 C240,22 180,6 120,16 C60,24 30,10 0,18 Z' fill='black'/></svg>\");\n  mask-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 24' preserveAspectRatio='none'><path d='M0,0 L1200,0 L1200,8 C1140,22 1080,2 1020,14 C960,24 900,6 840,16 C780,24 720,4 660,14 C600,22 540,6 480,16 C420,24 360,4 300,14 C240,22 180,6 120,16 C60,24 30,10 0,18 Z' fill='black'/></svg>\");\n  -webkit-mask-size:100% 100%; mask-size:100% 100%;\n}\n.torn-top::before{\n  content:\"\"; position:absolute; left:0; right:0; top:-1px; height:22px;\n  background:inherit;\n  -webkit-mask-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 24' preserveAspectRatio='none'><path d='M0,24 L1200,24 L1200,16 C1140,2 1080,22 1020,10 C960,0 900,18 840,8 C780,0 720,20 660,10 C600,2 540,18 480,8 C420,0 360,20 300,10 C240,2 180,18 120,8 C60,0 30,14 0,6 Z' fill='black'/></svg>\");\n  mask-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 24' preserveAspectRatio='none'><path d='M0,24 L1200,24 L1200,16 C1140,2 1080,22 1020,10 C960,0 900,18 840,8 C780,0 720,20 660,10 C600,2 540,18 480,8 C420,0 360,20 300,10 C240,2 180,18 120,8 C60,0 30,14 0,6 Z' fill='black'/></svg>\");\n  -webkit-mask-size:100% 100%; mask-size:100% 100%;\n}\n\n.scallop-top{\n  -webkit-mask-image: radial-gradient(circle 14px at 14px 0, transparent 13px, black 14px);\n  mask-image: radial-gradient(circle 14px at 14px 0, transparent 13px, black 14px);\n  -webkit-mask-size: 28px 100%;\n  mask-size: 28px 100%;\n  -webkit-mask-repeat: repeat-x;\n  mask-repeat: repeat-x;\n}\n\n/* paper fold spine */\n.spine{\n  position:absolute; top:0; bottom:0; left:50%; width:60px; transform:translateX(-50%);\n  background: linear-gradient(to right, transparent 0%, rgba(58,44,92,0.0) 35%, rgba(58,44,92,0.35) 50%, rgba(58,44,92,0.0) 65%, transparent 100%);\n  pointer-events:none; z-index:2;\n}\n.spine::after{\n  content:\"\"; position:absolute; left:50%; top:0; bottom:0; width:1px;\n  background:repeating-linear-gradient(to bottom, rgba(58,44,92,0.6) 0 6px, transparent 6px 10px);\n}\n\n/* shadows */\n.fold-shadow{ filter: drop-shadow(0 18px 18px rgba(58,44,92,0.35)) drop-shadow(0 4px 0 rgba(58,44,92,0.2)); }\n.pop-shadow{ box-shadow: 0 30px 40px -10px rgba(58,44,92,.35), 0 8px 0 -4px rgba(58,44,92,.18); }\n\n/* washi tape */\n.washi{\n  position:absolute; height:22px; width:120px;\n  background: repeating-linear-gradient(45deg, rgba(224,130,68,.55) 0 8px, rgba(224,130,68,.4) 8px 16px);\n  border-left:1px dashed rgba(58,44,92,.25);\n  border-right:1px dashed rgba(58,44,92,.25);\n  box-shadow: 0 2px 3px rgba(0,0,0,.1);\n}\n\n/* speech bubble */\n.bubble{\n  position:relative; background:var(--cream); border:2px solid var(--ink); border-radius: 22px 28px 24px 26px;\n  padding: 14px 18px; box-shadow: 4px 4px 0 var(--ink);\n}\n.bubble::after{\n  content:\"\"; position:absolute; width:18px; height:18px; background:var(--cream);\n  border-left:2px solid var(--ink); border-bottom:2px solid var(--ink);\n  transform: rotate(-30deg); left:-10px; bottom:18px;\n  border-radius: 0 0 0 6px;\n}\n.bubble.right::after{ left:auto; right:-10px; transform: rotate(150deg); border-radius:0 0 0 6px; }\n\n/* book spines */\n.spine-book{\n  width:62px; height:300px; display:flex; align-items:center; justify-content:center;\n  position:relative; transform-origin:bottom center; cursor:pointer;\n  border-radius: 4px 4px 2px 2px;\n  box-shadow: inset -6px 0 0 rgba(0,0,0,.15), inset 6px 0 0 rgba(255,255,255,.08), 0 14px 12px -8px rgba(0,0,0,.4);\n}\n.spine-book .title{ writing-mode: vertical-rl; transform: rotate(180deg); color:var(--cream); font-family:'Fraunces',serif; font-weight:600; letter-spacing:.05em;}\n.ribbon{ position:absolute; top:-6px; left:50%; transform:translateX(-50%); width:14px; height:60px; background:var(--crimson); border-radius:2px; box-shadow:0 2px 0 rgba(0,0,0,.25); opacity:0; transition: opacity .3s, height .3s;}\n.spine-book:hover .ribbon{ opacity:1; height:120px; }\n.spine-book:hover{ transform: translateY(-10px) rotate(-1deg); }\n\n/* hero book cover tilt */\n.book-cover{\n  transform: perspective(1400px) rotateX(8deg) rotateY(-12deg) rotateZ(-2deg);\n}\n\n/* dotted divider */\n.dotted{ background-image: radial-gradient(circle, var(--ink) 1.5px, transparent 1.5px); background-size: 12px 12px; background-repeat: repeat-x; background-position: center; height:12px;}\n\n/* nav link underline */\n.nav-link{ position:relative; }\n.nav-link::after{ content:\"\"; position:absolute; left:0; right:0; bottom:-6px; height:6px;\n  background: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 6'><path d='M0,3 Q15,0 30,3 T60,3' stroke='%23E08244' stroke-width='2' fill='none'/></svg>\") repeat-x;\n  opacity:0; transform: translateY(3px);\n}\n.nav-link:hover::after{ opacity:1; transform:translateY(0); transition: .3s;}\n\n.btn-crimson{ background:var(--crimson); color:var(--cream); border:2px solid var(--ink); box-shadow: 4px 4px 0 var(--ink); border-radius: 30px 26px 28px 24px;}\n.btn-crimson:hover{ transform: translate(-2px,-2px); box-shadow: 6px 6px 0 var(--ink);}\n.btn-pumpkin{ background:var(--pumpkin); color:var(--ink); border:2px solid var(--ink); box-shadow: 4px 4px 0 var(--ink); border-radius: 24px 30px 22px 28px;}\n.btn-pumpkin:hover{ transform: translate(-2px,-2px); box-shadow: 6px 6px 0 var(--ink);}\n\n/* satchel */\n.satchel{\n  background:var(--pumpkin); border:2px solid var(--ink);\n  border-radius: 18px 18px 22px 22px / 14px 14px 28px 28px;\n  box-shadow: 6px 6px 0 var(--ink);\n}\n.satchel-flap{\n  position:absolute; top:-10px; left:8%; right:8%; height:30px; background:#c46a30; border:2px solid var(--ink);\n  border-radius: 30px 30px 8px 8px / 22px 22px 4px 4px;\n}\n\n/* pop element */\n.pop-up{ transform-origin: bottom center; }\n\n/* age chip */\n.chip{ background:var(--mint); border:2px solid var(--ink); border-radius: 999px; padding:4px 14px; font-weight:600; font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:var(--ink); box-shadow:2px 2px 0 var(--ink);}\n\n/* star decorative */\n.star-deco{ color:var(--pumpkin); }\n\n/* shelf */\n.shelf-board{ background: linear-gradient(180deg,#8b5e3c, #6b4528); height:26px; border-radius: 4px; box-shadow: 0 10px 18px -8px rgba(0,0,0,.5), inset 0 2px 0 rgba(255,255,255,.15); position:relative;}\n.shelf-board::after{ content:\"\"; position:absolute; left:0; right:0; top:-2px; height:2px; background:rgba(0,0,0,.35);}\n\n/* tickets/flap */\n.flap-card{ background: var(--cream); border:2px solid var(--ink); box-shadow: 6px 6px 0 var(--ink); }\n\n/* cursor decorations */\n.crease-h{ position:absolute; left:0; right:0; height:1px; background: repeating-linear-gradient(to right, rgba(58,44,92,.4) 0 6px, transparent 6px 10px); }\n\n</style>\n\n<div class=\"paper text-[var(--ink)] relative overflow-hidden\" data-kid=\"1\">\n\n\n<header class=\"relative z-40\" data-kid=\"2\">\n  <div class=\"max-w-[1280px] mx-auto px-8 py-5 flex items-center justify-between\" data-kid=\"3\">\n    <div class=\"flex items-center gap-3\" data-kid=\"4\">\n      <div class=\"relative w-11 h-11 rounded-full bg-[var(--ink)] flex items-center justify-center\" data-kid=\"5\">\n        <span class=\"font-display text-[var(--cream)] text-2xl italic font-bold\" data-kid=\"6\">F</span>\n        <span class=\"absolute -top-1 -right-1 w-3 h-3 rounded-full bg-[var(--crimson)]\" data-kid=\"7\"></span>\n      </div>\n      <div class=\"leading-tight\" data-kid=\"8\">\n        <div class=\"font-display text-xl font-bold tracking-tight\" data-kid=\"9\">Foxglove &amp; Folio</div>\n        <div class=\"text-[10px] tracking-[0.25em] uppercase opacity-70\" data-kid=\"10\">picture books · est. 2014</div>\n      </div>\n    </div>\n    <nav class=\"hidden md:flex items-center gap-9 text-sm font-medium\" data-kid=\"11\">\n      <a class=\"nav-link\" href=\"#\" data-kid=\"12\">Spreads</a>\n      <a class=\"nav-link\" href=\"#\" data-kid=\"13\">Library</a>\n      <a class=\"nav-link\" href=\"#\" data-kid=\"14\">Authors</a>\n      <a class=\"nav-link\" href=\"#\" data-kid=\"15\">Workshops</a>\n      <a class=\"nav-link\" href=\"#\" data-kid=\"16\">Shop</a>\n    </nav>\n    <div class=\"flex items-center gap-3\" data-kid=\"17\">\n      <button class=\"text-sm px-4 py-2 rounded-full border-2 border-[var(--ink)] font-medium\" data-kid=\"18\">Sign in</button>\n      <button class=\"btn-pumpkin text-sm px-4 py-2 font-semibold\" data-kid=\"19\">Subscribe</button>\n    </div>\n  </div>\n  <div class=\"dotted max-w-[1280px] mx-auto\" data-kid=\"20\"></div>\n</header>\n\n\n<section class=\"relative px-8 pt-16 pb-28 overflow-hidden\" data-kid=\"21\">\n  <div class=\"absolute top-20 left-10 font-display italic text-[15px] opacity-60\" data-kid=\"22\">— turn the page, dear reader —</div>\n  <div class=\"absolute top-24 right-12 flex items-center gap-2 text-[12px] tracking-[.25em] uppercase opacity-70\" data-kid=\"23\">\n    <span data-kid=\"24\">Vol. XI</span><span data-kid=\"25\">·</span><span data-kid=\"26\">Spring Almanac</span>\n  </div>\n\n  <div class=\"max-w-[1280px] mx-auto relative\" data-kid=\"27\">\n    \n    <div class=\"grid grid-cols-12 gap-0 relative\" data-kid=\"28\">\n      <div class=\"col-span-6 relative\" data-kid=\"29\">\n        <div class=\"relative h-[640px] paper border-2 border-[var(--ink)] rounded-l-[40px_60px] rounded-r-none fold-shadow\" style=\"border-right:none; transform: perspective(1400px) rotateY(8deg); transform-origin: right center;\" data-kid=\"30\">\n          <div class=\"absolute inset-0 grain\" data-kid=\"31\"></div>\n          <div class=\"p-12 relative h-full flex flex-col justify-between\" data-kid=\"32\">\n            <div data-kid=\"33\">\n              <div class=\"chip mb-6 inline-block\" data-kid=\"34\">An Unfolding Catalog</div>\n              <h1 class=\"font-display text-[92px] leading-[0.88] font-black tracking-tight text-[var(--ink)]\" data-kid=\"35\">\n                Stories that<br data-kid=\"36\">\n                <span class=\"italic-d font-light\" data-kid=\"37\">unfold</span><br data-kid=\"38\">\n                in the<br data-kid=\"39\">\n                <span class=\"text-[var(--pumpkin)]\" data-kid=\"40\">dark.</span>\n              </h1>\n            </div>\n            <div class=\"flex items-end justify-between\" data-kid=\"41\">\n              <p class=\"font-display italic-d text-lg max-w-[280px] leading-snug\" data-kid=\"42\">\n                A house of dreamlike picture-books for small humans &amp; the large ones reading aloud.\n              </p>\n              <div class=\"text-right text-[11px] tracking-[.25em] uppercase\" data-kid=\"43\">\n                <div data-kid=\"44\">page</div><div class=\"font-display text-3xl not-italic\" data-kid=\"45\">001</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"spine\" data-kid=\"46\"></div>\n\n      \n      <div class=\"col-span-6 relative\" data-kid=\"47\">\n        <div class=\"relative h-[640px] paper-mint border-2 border-[var(--ink)] rounded-r-[40px_60px] fold-shadow overflow-hidden\" style=\"border-left:none; transform: perspective(1400px) rotateY(-8deg); transform-origin: left center;\" data-kid=\"48\">\n          <div class=\"absolute inset-0 grain\" data-kid=\"49\"></div>\n\n          \n          <div class=\"absolute left-1/2 -translate-x-1/2 bottom-10 pop-up\" data-kid=\"50\">\n            <div class=\"relative\" data-kid=\"51\">\n              <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/a993fd29-0101-46bc-9b8b-13bc576c1070/62e64792b21e49f1a5f3ed4867a2f4d1.png\" class=\"w-[340px] h-[440px] object-cover border-[3px] border-[var(--ink)] pop-shadow\" style=\"clip-path: polygon(8% 2%, 30% 0, 55% 3%, 80% 1%, 98% 5%, 100% 30%, 97% 60%, 100% 85%, 88% 100%, 60% 97%, 35% 100%, 12% 98%, 2% 90%, 0 60%, 3% 30%, 0 8%);\" alt decoding=\"async\" loading=\"lazy\" data-kid=\"52\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n              <div class=\"absolute -bottom-4 left-1/2 -translate-x-1/2 w-[200px] h-3 bg-[var(--ink)] rounded-full opacity-40 blur-sm\" data-kid=\"53\"></div>\n              \n              <div class=\"absolute -left-6 top-1/3 w-12 h-20 bg-[var(--pumpkin)] border-2 border-[var(--ink)] rounded-l-2xl pop-shadow flex items-center justify-center\" data-kid=\"54\">\n                <span class=\"font-display text-xs rotate-[-90deg] whitespace-nowrap font-bold\" data-kid=\"55\">FOLD A</span>\n              </div>\n              <div class=\"absolute -right-6 top-1/2 w-12 h-16 bg-[var(--crimson)] border-2 border-[var(--ink)] rounded-r-2xl pop-shadow flex items-center justify-center\" data-kid=\"56\">\n                <span class=\"font-display text-xs rotate-[90deg] text-[var(--cream)] whitespace-nowrap font-bold\" data-kid=\"57\">PULL ↑</span>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"absolute top-10 right-10 w-28 h-28 rounded-full border-2 border-[var(--ink)] overflow-hidden pop-shadow rotate-[8deg]\" data-kid=\"58\">\n            <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/a993fd29-0101-46bc-9b8b-13bc576c1070/5afded92fe554971a882e5d3d3c4ce01.png\" class=\"w-full h-full object-cover\" alt decoding=\"async\" loading=\"lazy\" data-kid=\"59\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n          </div>\n          \n          <svg class=\"absolute top-32 left-10 w-8 h-8 star-deco\" viewBox=\"0 0 24 24\" fill=\"currentColor\" data-kid=\"60\"><path d=\"M12 2l2.4 7.4H22l-6.2 4.5L18.2 22 12 17.5 5.8 22l2.4-8.1L2 9.4h7.6z\" data-kid=\"61\"></path></svg>\n          <svg class=\"absolute bottom-32 left-16 w-5 h-5 text-[var(--crimson)]\" viewBox=\"0 0 24 24\" fill=\"currentColor\" data-kid=\"62\"><path d=\"M12 2l2.4 7.4H22l-6.2 4.5L18.2 22 12 17.5 5.8 22l2.4-8.1L2 9.4h7.6z\" data-kid=\"63\"></path></svg>\n          <svg class=\"absolute top-24 left-1/2 w-4 h-4 text-[var(--ink)]\" viewBox=\"0 0 24 24\" fill=\"currentColor\" data-kid=\"64\"><path d=\"M12 2l2.4 7.4H22l-6.2 4.5L18.2 22 12 17.5 5.8 22l2.4-8.1L2 9.4h7.6z\" data-kid=\"65\"></path></svg>\n\n          \n          <div class=\"absolute bottom-6 right-8 text-[11px] tracking-[.25em] uppercase\" data-kid=\"66\">\n            <div class=\"font-display text-3xl not-italic text-right\" data-kid=\"67\">002</div>\n          </div>\n\n          \n          <div class=\"absolute top-12 left-12 w-16 h-16 rounded-full bg-[var(--cream)] border-2 border-[var(--ink)] pop-shadow flex items-center justify-center\" data-kid=\"68\">\n            <div class=\"w-10 h-10 rounded-full bg-[var(--pumpkin)] -ml-2\" data-kid=\"69\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-12 flex flex-wrap items-end justify-between gap-6\" data-kid=\"70\">\n      <div class=\"flex items-center gap-4\" data-kid=\"71\">\n        <button class=\"btn-crimson px-7 py-4 font-semibold flex items-center gap-3\" data-kid=\"72\">\n          <i class=\"ti ti-book-2 text-lg\" data-kid=\"73\"></i> Open the Catalogue\n        </button>\n        <button class=\"px-7 py-4 font-medium border-2 border-[var(--ink)] rounded-full bg-transparent hover:bg-[var(--ink)] hover:text-[var(--cream)] flex items-center gap-2\" data-kid=\"74\">\n          <i class=\"ti ti-player-play text-base\" data-kid=\"75\"></i> Watch a pop-up\n        </button>\n      </div>\n      <div class=\"flex items-center gap-8\" data-kid=\"76\">\n        <div data-kid=\"77\">\n          <div class=\"font-display text-4xl font-bold\" data-kid=\"78\">62</div>\n          <div class=\"text-[11px] tracking-[.2em] uppercase opacity-70\" data-kid=\"79\">titles in print</div>\n        </div>\n        <div class=\"w-px h-12 bg-[var(--ink)] opacity-30\" data-kid=\"80\"></div>\n        <div data-kid=\"81\">\n          <div class=\"font-display text-4xl font-bold\" data-kid=\"82\">14</div>\n          <div class=\"text-[11px] tracking-[.2em] uppercase opacity-70\" data-kid=\"83\">illustrators</div>\n        </div>\n        <div class=\"w-px h-12 bg-[var(--ink)] opacity-30\" data-kid=\"84\"></div>\n        <div data-kid=\"85\">\n          <div class=\"font-display text-4xl font-bold\" data-kid=\"86\">9</div>\n          <div class=\"text-[11px] tracking-[.2em] uppercase opacity-70\" data-kid=\"87\">languages</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"relative pt-8 pb-20 px-8\" data-kid=\"88\">\n  <div class=\"max-w-[1280px] mx-auto\" data-kid=\"89\">\n    <div class=\"flex items-center gap-4 mb-10\" data-kid=\"90\">\n      <span class=\"font-display italic text-sm\" data-kid=\"91\">notes from the margins</span>\n      <div class=\"flex-1 dotted\" data-kid=\"92\"></div>\n      <span class=\"text-[11px] tracking-[.25em] uppercase\" data-kid=\"93\">scroll →</span>\n    </div>\n    <div class=\"grid grid-cols-12 gap-6\" data-kid=\"94\">\n      \n      <div class=\"col-span-3 relative flap-card p-6 rotate-[-1.5deg]\"