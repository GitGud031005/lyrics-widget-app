      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --lp-cream: #F4E9D0;\n    --lp-cream2: #EFE0BE;\n    --lp-ink: #3A2C5C;\n    --lp-pumpkin: #E08244;\n    --lp-mint: #A8D6B8;\n    --lp-crimson: #C23D3D;\n  }\n\n  body {\n    background-color: var(--lp-cream);\n    color: var(--lp-ink);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-display { font-family: 'Fraunces', serif; }\n\n  .paper-grain {\n    background-image: radial-gradient(var(--lp-ink) 1px, transparent 1px);\n    background-size: 20px 20px;\n    opacity: 0.04;\n  }\n\n  .paper-cut {\n    clip-path: polygon(1% 2%, 8% 0%, 22% 3%, 45% 1%, 70% 2%, 88% 0%, 99% 3%, 100% 18%, 98% 40%, 100% 62%, 99% 82%, 100% 97%, 84% 100%, 60% 98%, 36% 100%, 14% 99%, 2% 100%, 0% 80%, 2% 55%, 0% 30%, 1% 12%);\n  }\n\n  .paper-shadow {\n    box-shadow: 0 10px 18px -8px rgba(58, 44, 92, 0.35), 0 4px 0 rgba(58, 44, 92, 0.2);\n  }\n\n  .dotted-divider {\n    background-image: radial-gradient(circle, var(--lp-ink) 1.5px, transparent 1.5px);\n    background-size: 12px 12px;\n    background-repeat: repeat-x;\n    background-position: center;\n    height: 12px;\n  }\n</style>\n\n<div class=\"min-h-screen relative flex flex-col\" data-kid=\"1\">\n  <div class=\"fixed inset-0 paper-grain pointer-events-none\" data-kid=\"2\"></div>\n\n  <header class=\"sticky top-0 z-50 bg-[var(--lp-cream)]/95 backdrop-blur-sm pt-4 pb-2 border-b border-[var(--lp-ink)]/10\" data-kid=\"3\">\n    <div class=\"px-6 flex flex-col items-center text-center\" data-kid=\"4\">\n      <h1 class=\"font-display text-lg font-black tracking-widest leading-tight uppercase\" data-kid=\"5\">Lyrico & Verse</h1>\n      <p class=\"text-[8px] tracking-[0.2em] opacity-80 uppercase font-extrabold\" data-kid=\"6\">manual lyrics widget · est. 2025</p>\n    </div>\n    \n    <div class=\"mt-4 px-6\" data-kid=\"7\">\n      <div class=\"flex items-center justify-between text-[11px] tracking-widest opacity-90 italic font-display\" data-kid=\"8\">\n        <span data-kid=\"9\">— find your voice, dear reader —</span>\n        <span class=\"not-italic font-sans text-[9px] font-black opacity-60\" data-kid=\"10\">VOL. I</span>\n      </div>\n    </div>\n    \n    <div class=\"dotted-divider mt-2 opacity-40\" data-kid=\"11\"></div>\n  </header>\n\n  <main class=\"flex-1 px-4 pt-6 pb-20 space-y-4\" data-kid=\"12\">\n    \n    <div class=\"mb-6\" data-kid=\"13\">\n      <div class=\"paper-cut bg-[var(--lp-ink)]/10 border border-[var(--lp-ink)]/20 p-4 flex items-center gap-3 paper-shadow\" data-kid=\"14\">\n        <i class=\"ti ti-pencil-line text-lg opacity-80\" data-kid=\"15\"></i>\n        <span class=\"text-[var(--lp-ink)] text-sm font-black tracking-tight\" data-kid=\"16\">blue</span>\n        <div class=\"ml-auto w-5 h-5 rounded-full bg-[var(--lp-ink)]/15 flex items-center justify-center\" data-kid=\"17\">\n          <i class=\"ti ti-x text-[10px] font-black\" data-kid=\"18\"></i>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"space-y-4\" data-kid=\"19\">\n      \n      <div class=\"relative\" data-kid=\"20\">\n        <div class=\"paper-cut bg-white/70 border border-[var(--lp-ink)]/20 p-4 pl-16 paper-shadow flex items-center justify-between\" data-kid=\"21\">\n          <div class=\"absolute left-0 top-0 bottom-0 w-12 bg-[var(--lp-mint)] flex items-start justify-center pt-2\" data-kid=\"22\">\n            <div class=\"w-2.5 h-6 bg-[var(--lp-crimson)] shadow-sm\" data-kid=\"23\"></div>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"24\">\n            <span class=\"font-display text-base font-black leading-tight\" data-kid=\"25\">(Don't Fear) The Reap...</span>\n            <span class=\"text-xs font-bold opacity-80\" data-kid=\"26\">Blue Öyster Cult</span>\n          </div>\n          <div class=\"flex flex-col items-end gap-1.5\" data-kid=\"27\">\n            <span class=\"text-[9px] font-black bg-[var(--lp-mint)] px-2 py-1 rounded border border-[var(--lp-ink)] uppercase tracking-tighter\" data-kid=\"28\">Synced</span>\n            <span class=\"text-[10px] font-black font-mono opacity-60 tracking-tighter\" data-kid=\"29\">5:06</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative\" data-kid=\"30\">\n        <div class=\"paper-cut bg-white/70 border border-[var(--lp-ink)]/20 p-4 pl-16 paper-shadow flex items-center justify-between\" data-kid=\"31\">\n          <div class=\"absolute left-0 top-0 bottom-0 w-12 bg-[var(--lp-mint)] flex items-start justify-center pt-2\" data-kid=\"32\">\n            <div class=\"w-2.5 h-6 bg-[var(--lp-crimson)] shadow-sm\" data-kid=\"33\"></div>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"34\">\n            <span class=\"font-display text-base font-black leading-tight\" data-kid=\"35\">Fish In The Sea</span>\n            <span class=\"text-xs font-bold opacity-80\" data-kid=\"36\">Dustin Lynch</span>\n          </div>\n          <div class=\"flex flex-col items-end gap-1.5\" data-kid=\"37\">\n            <span class=\"text-[9px] font-black bg-[var(--lp-mint)] px-2 py-1 rounded border border-[var(--lp-ink)] uppercase tracking-tighter\" data-kid=\"38\">Synced</span>\n            <span class=\"text-[10px] font-black font-mono opacity-60 tracking-tighter\" data-kid=\"39\">2:50</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative\" data-kid=\"40\">\n        <div class=\"paper-cut bg-white/70 border border-[var(--lp-ink)]/20 p-4 pl-16 paper-shadow flex items-center justify-between\" data-kid=\"41\">\n          <div class=\"absolute left-0 top-0 bottom-0 w-12 bg-[var(--lp-pumpkin)] flex items-start justify-center pt-2\" data-kid=\"42\">\n            <div class=\"w-2.5 h-6 bg-[var(--lp-crimson)] shadow-sm\" data-kid=\"43\"></div>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"44\">\n            <span class=\"font-display text-base font-black leading-tight\" data-kid=\"45\">I'm Good (Blue)</span>\n            <span class=\"text-xs font-bold opacity-80\" data-kid=\"46\">David Guetta</span>\n          </div>\n          <div class=\"flex flex-col items-end gap-1.5\" data-kid=\"47\">\n            <span class=\"text-[10px] font-black font-mono opacity-40 tracking-tighter\" data-kid=\"48\">2:55</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative\" data-kid=\"49\">\n        <div class=\"paper-cut bg-white/70 border border-[var(--lp-ink)]/20 p-4 pl-16 paper-shadow flex items-center justify-between\" data-kid=\"50\">\n          <div class=\"absolute left-0 top-0 bottom-0 w-12 bg-[var(--lp-mint)] flex items-start justify-center pt-2\" data-kid=\"51\">\n            <div class=\"w-2.5 h-6 bg-[var(--lp-crimson)] shadow-sm\" data-kid=\"52\"></div>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"53\">\n            <span class=\"font-display text-base font-black leading-tight\" data-kid=\"54\">Lying to Myself</span>\n            <span class=\"text-xs font-bold opacity-80\" data-kid=\"55\">Leland Blue</span>\n          </div>\n          <div class=\"flex flex-col items-end gap-1.5\" data-kid=\"56\">\n            <span class=\"text-[9px] font-black bg-[var(--lp-mint)] px-2 py-1 rounded border border-[var(--lp-ink)] uppercase tracking-tighter\" data-kid=\"57\">Synced</span>\n            <span class=\"text-[10px] font-black font-mono opacity-60 tracking-tighter\" data-kid=\"58\">4:00</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative\" data-kid=\"59\">\n        <div class=\"paper-cut bg-white/70 border border-[var(--lp-ink)]/20 p-4 pl-16 paper-shadow flex items-center justify-between\" data-kid=\"60\">\n          <div class=\"absolute left-0 top-0 bottom-0 w-12 bg-[var(--lp-pumpkin)] flex items-start justify-center pt-2\" data-kid=\"61\">\n            <div class=\"w-2.5 h-6 bg-[var(--lp-crimson)] shadow-sm\" data-kid=\"62\"></div>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"63\">\n            <span class=\"font-display text-base font-black leading-tight\" data-kid=\"64\">My Blue Angel</span>\n            <span class=\"text-xs font-bold opacity-80\" data-kid=\"65\">Aaron Tippin</span>\n          </div>\n          <div class=\"flex flex-col items-end gap-1.5\" data-kid=\"66\">\n            <span class=\"text-[10px] font-black font-mono opacity-40 tracking-tighter\" data-kid=\"67\">3:24</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  <nav class=\"fixed bottom-0 left-0 right-0 bg-white/90 backdrop-blur-md border-t border-[var(--lp-ink)]/10 flex justify-around py-3 px-8 z-50\" data-kid=\"68\">\n    <div class=\"flex flex-col items-center text-[var(--lp-crimson)]\" data-kid=\"69\">\n      <i class=\"ti ti-search text-[24px] font-black\" data-kid=\"70\"></i>\n      <span class=\"text-[10px] font-black mt-1\" data-kid=\"71\">Search</span>\n    </div>\n    <div class=\"flex flex-col items-center opacity-40\" data-kid=\"72\">\n      <i class=\"ti ti-settings text-[24px]\" data-kid=\"73\"></i>\n      <span class=\"text-[10px] font-bold mt-1\" data-kid=\"74\">Settings</span>\n    </div>\n  </nav>\n</div>",
