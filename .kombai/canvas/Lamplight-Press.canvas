      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --lp-cream: #F4E9D0;\n    --lp-cream-2: #EFE0BE;\n    --lp-ink: #3A2C5C;\n    --lp-pumpkin: #E08244;\n    --lp-mint: #A8D6B8;\n    --lp-crimson: #C23D3D;\n  }\n\n  .font-display { font-family: 'Fraunces', serif; }\n  .font-body { font-family: 'Inter', sans-serif; }\n\n  .paper {\n    background-color: var(--lp-cream);\n    background-image: \n      radial-gradient(var(--lp-ink) 0.5px, transparent 0.5px),\n      radial-gradient(var(--lp-ink) 0.5px, transparent 0.5px);\n    background-size: 22px 22px, 11px 11px;\n    background-position: 0 0, 5px 5px;\n    opacity: 1;\n  }\n\n  .paper-grain::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0.03;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  .paper-cut {\n    clip-path: polygon(1% 2%, 8% 0%, 22% 3%, 45% 1%, 70% 2%, 88% 0%, 99% 3%, 100% 18%, 98% 40%, 100% 62%, 99% 82%, 100% 97%, 84% 100%, 60% 98%, 36% 100%, 14% 99%, 2% 100%, 0% 80%, 2% 55%, 0% 30%, 1% 12%);\n  }\n\n  .washi-tape {\n    background: repeating-linear-gradient(45deg, rgba(224, 130, 68, 0.25) 0 8px, rgba(224, 130, 68, 0.15) 8px 16px);\n    border: 1px dashed rgba(58, 44, 92, 0.1);\n    transform: rotate(-0.8deg);\n  }\n\n  .dotted-divider {\n    background-image: radial-gradient(circle, var(--lp-ink) 1.2px, transparent 1.2px);\n    background-size: 10px 1px;\n    background-repeat: repeat-x;\n    height: 1px;\n    opacity: 0.3;\n  }\n\n  .paper-shadow {\n    box-shadow: 0 10px 20px -5px rgba(58, 44, 92, 0.25), 0 4px 0 rgba(58, 44, 92, 0.1);\n  }\n</style>\n\n<div class=\"paper min-h-screen paper-grain relative flex flex-col font-body text-[var(--lp-ink)]\" data-kid=\"1\">\n  \n  \n  <header class=\"pt-8 pb-6 px-6 text-center\" data-kid=\"2\">\n    <h1 class=\"font-display text-[26px] font-black leading-tight mb-1\" data-kid=\"3\">Bohemian Rhapsody</h1>\n    <p class=\"font-display text-base italic font-medium opacity-70\" data-kid=\"4\">Queen</p>\n    \n    <div class=\"flex items-center justify-center gap-3 mt-4\" data-kid=\"5\">\n      <div class=\"flex items-center gap-1.5 text-[11px] font-bold opacity-50\" data-kid=\"6\">\n        <i class=\"ti ti-clock\" data-kid=\"7\"></i>\n        <span class=\"tracking-widest\" data-kid=\"8\">5:54</span>\n      </div>\n      \n      <div class=\"paper-cut bg-[rgba(168,214,184,0.3)] px-3 py-1.5 border border-[var(--lp-ink)]\" data-kid=\"9\">\n        <span class=\"text-[9px] font-black tracking-widest\" data-kid=\"10\">SYNCED</span>\n      </div>\n    </div>\n  </header>\n\n  <div class=\"dotted-divider mx-6\" data-kid=\"11\"></div>\n\n  \n  <main class=\"flex-1 relative overflow-hidden\" data-kid=\"12\">\n    <div class=\"py-6 flex flex-col\" data-kid=\"13\">\n      \n      <div class=\"px-6 py-3.5 opacity-40\" data-kid=\"14\">\n        <div class=\"flex items-center gap-4\" data-kid=\"15\">\n          <span class=\"w-10 text-right text-[10px] font-bold font-mono\" data-kid=\"16\">00:30</span>\n          <p class=\"font-display text-base font-medium\" data-kid=\"17\">Is this the real life?</p>\n        </div>\n      </div>\n\n      \n      <div class=\"relative py-3.5\" data-kid=\"18\">\n        <div class=\"absolute inset-0 washi-tape mx-4\" data-kid=\"19\"></div>\n        <div class=\"relative px-6 flex items-center gap-4\" data-kid=\"20\">\n          <span class=\"w-10 text-right text-[10px] font-bold font-mono opacity-80\" data-kid=\"21\">00:34</span>\n          <p class=\"font-display text-[22px] font-black scale-[1.05] origin-left\" data-kid=\"22\">Is this just fantasy?</p>\n        </div>\n      </div>\n\n      \n      <div class=\"px-6 py-3.5 opacity-40\" data-kid=\"23\">\n        <div class=\"flex items-center gap-4\" data-kid=\"24\">\n          <span class=\"w-10 text-right text-[10px] font-bold font-mono\" data-kid=\"25\">00:38</span>\n          <p class=\"font-display text-base font-medium\" data-kid=\"26\">Caught in a landslide,</p>\n        </div>\n      </div>\n      \n      <div class=\"px-6 py-3.5 opacity-40\" data-kid=\"27\">\n        <div class=\"flex items-center gap-4\" data-kid=\"28\">\n          <span class=\"w-10 text-right text-[10px] font-bold font-mono\" data-kid=\"29\">00:42</span>\n          <p class=\"font-display text-base font-medium\" data-kid=\"30\">No escape from reality.</p>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-6 left-6 opacity-30 -rotate-6 pointer-events-none\" data-kid=\"31\">\n      <img src=\"https://kombai-assets.b-cdn.net/generated_assets/546bcd6a-ae6d-45c1-85a6-b370c2cc2f99/7faea13a823a42299a4a3a537ac4b85b.jpg\" class=\"w-[70px] h-[90px] object-cover paper-cut border border-[var(--lp-ink)] paper-shadow\" decoding=\"async\" loading=\"lazy\" data-kid=\"32\">\n    </div>\n  </main>\n\n  \n  <footer class=\"p-6 bg-[var(--lp-cream)] bg-opacity-95\" data-kid=\"33\">\n    <div class=\"dotted-divider mb-6 -mx-6\" data-kid=\"34\"></div>\n    \n    <button class=\"w-full flex items-center justify-center gap-3 py-5 paper-cut bg-[var(--lp-pumpkin)] border-2 border-[var(--lp-ink)] paper-shadow group active:scale-[0.98] transition-transform\" data-kid=\"35\">\n      <i class=\"ti ti-hand-tap text-xl\" data-kid=\"36\"></i>\n      <span class=\"font-display text-base font-black tracking-widest\" data-kid=\"37\">SET TO WIDGET</span>\n    </button>\n  </footer>\n</div>",
