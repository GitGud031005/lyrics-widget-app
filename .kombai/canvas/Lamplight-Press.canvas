    "var_946d313d548f": {
      "type": "variant",
      "label": "Lyrico Widget - Medium",
      "parentId": "var_9c5b11d1a259",
      "themeId": null,
      "rect": {
        "x": 5650,
        "y": 0,
        "w": 322,
        "h": 812
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,700&family=Inter:wght@300;400;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --cream: #F4E9D0;\n    --cream-dark: #EFE0BE;\n    --ink: #3A2C5C;\n    --pumpkin: #E08244;\n    --mint: #A8D6B8;\n    --crimson: #C23D3D;\n  }\n\n  body {\n    margin: 0;\n    padding: 20px;\n    background-color: #e5e7eb;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n    font-family: 'Inter', sans-serif;\n  }\n\n  .widget-container {\n    width: 322px;\n    height: 148px;\n    background-color: var(--cream);\n    border: 2px solid var(--ink);\n    border-radius: 22px;\n    position: relative;\n    overflow: clip;\n    box-shadow: \n      0 12px 24px -10px rgba(58, 44, 92, 0.3),\n      4px 6px 0px rgba(58, 44, 92, 0.04);\n    display: flex;\n    padding: 14px;\n    box-sizing: border-box;\n  }\n\n  /* Paper Texture */\n  .paper-grain {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0.15;\n    mix-blend-mode: multiply;\n    background-image: \n      radial-gradient(var(--ink) 0.5px, transparent 0.5px),\n      radial-gradient(var(--pumpkin) 0.5px, transparent 0.5px);\n    background-size: 14px 14px, 19px 19px;\n    background-position: 0 0, 7px 7px;\n  }\n\n  .grain-overlay {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0.08;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 250 250' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  /* Typography */\n  .font-fraunces {\n    font-family: 'Fraunces', serif;\n    font-optical-sizing: auto;\n  }\n\n  /* Cut styles */\n  .cut-highlight {\n    clip-path: polygon(0% 4%, 98% 1%, 100% 92%, 1% 99%);\n  }\n\n  .cut-tab-left {\n    clip-path: polygon(8% 2%, 95% 5%, 90% 98%, 2% 90%);\n  }\n\n  .cut-tab-center {\n    clip-path: polygon(2% 8%, 98% 3%, 94% 94%, 5% 98%);\n  }\n\n  .cut-tab-right {\n    clip-path: polygon(5% 1%, 92% 6%, 99% 92%, 4% 96%);\n  }\n\n  /* Controls */\n  .control-btn {\n    width: 30px;\n    height: 34px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border: 1.5px solid var(--ink);\n    transition: transform 0.1s;\n  }\n\n  .control-btn:active {\n    transform: scale(0.95) translateY(1px);\n  }\n\n  /* Lyric lines */\n  .lyric-line {\n    line-clamp: 2;\n    display: -webkit-box;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n    transition: all 0.3s ease;\n  }\n\n  .lyric-line.muted {\n    color: rgba(58, 44, 92, 0.55);\n    font-style: italic;\n    font-size: 10px;\n    font-weight: 400;\n    letter-spacing: -0.01em;\n    line-height: 1.2;\n  }\n\n  .lyric-line.active {\n    color: var(--ink);\n    font-size: 12.5px;\n    font-weight: 900;\n    position: relative;\n    padding: 4px 12px;\n    margin: 4px -8px;\n    background-color: var(--mint);\n    z-index: 1;\n    clip-path: polygon(0% 4%, 98% 1%, 100% 92%, 1% 99%);\n    line-height: 1.1;\n  }\n\n  /* Dotted Divider */\n  .ink-dots {\n    height: 1px;\n    background-image: linear-gradient(to right, var(--ink) 25%, transparent 25%);\n    background-size: 4px 1px;\n    background-repeat: repeat-x;\n    opacity: 0.15;\n  }\n\n  .washi-tape {\n    position: absolute;\n    width: 60px;\n    height: 16px;\n    background: repeating-linear-gradient(45deg, rgba(224, 130, 68, 0.3) 0 6px, rgba(224, 130, 68, 0.15) 6px 12px);\n    border-left: 1px dashed rgba(58, 44, 92, 0.2);\n    border-right: 1px dashed rgba(58, 44, 92, 0.2);\n    transform: rotate(-3deg);\n    top: -4px;\n    left: 40px;\n    z-index: 5;\n    pointer-events: none;\n  }\n</style>\n\n<div class=\"widget-container\" data-kid=\"1\">\n  \n  <div class=\"paper-grain\" data-kid=\"2\"></div>\n  <div class=\"grain-overlay\" data-kid=\"3\"></div>\n  <div class=\"washi-tape\" data-kid=\"4\"></div>\n  \n  <div class=\"relative z-10 w-full flex gap-3 h-full\" data-kid=\"5\">\n    \n    \n    <div class=\"flex-1 flex flex-col justify-between py-1 px-1\" data-kid=\"6\">\n      <div class=\"space-y-1\" data-kid=\"7\">\n        <div class=\"text-[8px] uppercase tracking-[0.25em] font-black text-[var(--ink)]/50 mb-4 flex items-center gap-2\" data-kid=\"8\">\n          <span class=\"w-2 h-0.5 bg-[var(--crimson)]\" data-kid=\"9\"></span>\n          <span data-kid=\"10\">Now Playing</span>\n        </div>\n        \n        <div class=\"flex flex-col gap-2 pr-4\" data-kid=\"11\">\n          \n          <div class=\"lyric-line muted\" data-kid=\"12\">\n            I'm holding onto something tight\n          </div>\n          \n          \n          <div class=\"lyric-line active shadow-[4px_4px_0_rgba(58,44,92,0.08)]\" data-kid=\"13\">\n            In the glow of the lamplight press\n          </div>\n          \n          \n          <div class=\"lyric-line muted\" data-kid=\"14\">\n            A thousand stories yet to write\n          </div>\n        </div>\n      </div>\n      \n      \n      <div class=\"flex items-center gap-3 pr-6 mb-1\" data-kid=\"15\">\n        <div class=\"ink-dots flex-1\" data-kid=\"16\"></div>\n        <span class=\"text-[9px] uppercase tracking-[0.2em] text-[var(--ink)]/50 font-black whitespace-nowrap\" data-kid=\"17\">Pg. 12/48</span>\n      </div>\n    </div>\n\n    \n    <div class=\"w-px h-full bg-repeat-y opacity-25 mx-1\" style=\"background-image: linear-gradient(to bottom, var(--ink) 60%, transparent 60%); background-size: 1px 12px;\" data-kid=\"18\"></div>\n\n    \n    <div class=\"w-[112px] shrink-0 flex flex-col justify-between items-end text-right py-1\" data-kid=\"19\">\n      \n      \n      <div class=\"w-full\" data-kid=\"20\">\n        <h2 class=\"font-fraunces text-[var(--ink)] text-[13px] font-black leading-[1.1] break-words line-clamp-2\" data-kid=\"21\">\n          Paper Hearts\n        </h2>\n        <p class=\"font-fraunces text-[var(--ink)]/60 text-[9px] italic leading-tight truncate mt-1\" data-kid=\"22\">\n          The Folio Collective\n        </p>\n      </div>\n\n      \n      <div class=\"flex gap-1.5\" data-kid=\"23\">\n        \n        <div class=\"relative\" data-kid=\"24\">\n          <div class=\"absolute inset-0 bg-[var(--ink)] opacity-20 translate-x-[3px] translate-y-[3px] cut-tab-left\" data-kid=\"25\"></div>\n          <button class=\"control-btn bg-[var(--pumpkin)] cut-tab-left relative z-10 hover:translate-y-[-1px] transition-transform\" data-kid=\"26\">\n            <i class=\"ti ti-player-skip-back-filled text-[var(--ink)] text-xs\" data-kid=\"27\"></i>\n          </button>\n        </div>\n\n        \n        <div class=\"relative\" data-kid=\"28\">\n          <div class=\"absolute inset-0 bg-[var(--ink)] opacity-20 translate-x-[3px] translate-y-[3px] cut-tab-center\" data-kid=\"29\"></div>\n          <button class=\"control-btn bg-[var(--crimson)] cut-tab-center relative z-10 hover:translate-y-[-1px] transition-transform\" data-kid=\"30\">\n            <i class=\"ti ti-rotate-clockwise text-[var(--cream)] text-sm font-bold\" data-kid=\"31\"></i>\n          </button>\n        </div>\n\n        \n        <div class=\"relative\" data-kid=\"32\">\n          <div class=\"absolute inset-0 bg-[var(--ink)] opacity-20 translate-x-[3px] translate-y-[3px] cut-tab-right\" data-kid=\"33\"></div>\n          <button class=\"control-btn bg-[var(--pumpkin)] cut-tab-right relative z-10 hover:translate-y-[-1px] transition-transform\" data-kid=\"34\">\n            <i class=\"ti ti-player-skip-forward-filled text-[var(--ink)] text-xs\" data-kid=\"35\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"mt-1 bg-[var(--ink)] text-[var(--cream)] text-[8px] px-2 py-0.5 rounded-sm font-bold uppercase tracking-widest opacity-90 shadow-sm\" style=\"clip-path: polygon(0% 5%, 100% 0%, 98% 95%, 2% 100%);\" data-kid=\"36\">\n        LYRICO+\n      </div>\n    </div>\n\n  </div>\n\n  \n  <div class=\"absolute -top-6 -right-6 w-12 h-12 bg-[var(--pumpkin)]/10 rounded-full blur-xl pointer-events-none\" data-kid=\"37\"></div>\n  <div class=\"absolute -bottom-4 -left-4 w-10 h-10 bg-[var(--mint)]/10 rounded-full blur-xl pointer-events-none\" data-kid=\"38\"></div>\n</div>\n",
