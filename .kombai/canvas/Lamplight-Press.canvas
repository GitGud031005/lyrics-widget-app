        "head": "<meta charset=\"UTF-8\" >\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" >\n    <script src=\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\"></script>"
