      "html": "\n<div class=\"paper text-[#3A2C5C] font-sans min-h-screen relative overflow-x-clip\" id=\"app-root\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n      --cream: #F4E9D0;\n      --cream-2: #EFE0BE;\n      --ink: #3A2C5C;\n      --pumpkin: #E08244;\n      --mint: #A8D6B8;\n      --crimson: #C23D3D;\n    }\n\n    body { margin: 0; padding: 0; }\n    .font-display { font-family: 'Fraunces', serif; }\n    .italic-d { font-family: 'Fraunces', serif; font-style: italic; }\n\n    /* Paper Textures */\n    .paper {\n      background-color: var(--cream);\n      background-image:\n        radial-gradient(rgba(58, 44, 92, 0.05) 1px, transparent 1px),\n        radial-gradient(rgba(192, 140, 80, 0.07) 1px, transparent 1px);\n      background-size: 20px 20px, 6px 6px;\n      background-position: 0 0, 3px 3px;\n    }\n\n    .grain::before {\n      content: \"\"; position: absolute; inset: 0; pointer-events: none; opacity: 0.25; mix-blend-mode: multiply;\n      background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n    }\n\n    /* Shapes & Borders */\n    .cut-card {\n      clip-path: polygon(1% 1%, 12% 0%, 25% 2%, 48% 0%, 75% 1%, 92% 0%, 99% 2%, 100% 15%, 98% 35%, 100% 55%, 99% 75%, 100% 98%, 88% 100%, 65% 98%, 35% 100%, 15% 99%, 2% 100%, 0% 85%, 1% 60%, 0% 35%, 1% 10%);\n    }\n\n    .flap-card {\n      background: var(--cream);\n      border: 2px solid var(--ink);\n      box-shadow: 4px 4px 0 var(--ink);\n      position: relative;\n      clip-path: polygon(0.5% 1%, 98% 0%, 100% 12%, 99% 88%, 100% 99%, 1% 100%, 0% 50%);\n    }\n\n    /* Shadows */\n    .fold-shadow { filter: drop-shadow(0 8px 12px rgba(58, 44, 92, 0.2)); }\n\n    /* Washi Tape */\n    .washi {\n      position: absolute; height: 18px; width: 70px;\n      background: repeating-linear-gradient(45deg, rgba(224, 130, 68, 0.5) 0 6px, rgba(224, 130, 68, 0.3) 6px 12px);\n      border-left: 1px dashed rgba(58, 44, 92, 0.2);\n      border-right: 1px dashed rgba(58, 44, 92, 0.2);\n      box-shadow: 0 1px 2px rgba(0,0,0,0.1);\n      z-index: 10;\n    }\n\n    /* Chips */\n    .chip {\n      border: 2px solid var(--ink);\n      border-radius: 999px;\n      padding: 2px 10px;\n      font-weight: 700;\n      font-size: 10px;\n      letter-spacing: 0.05em;\n      text-transform: uppercase;\n      box-shadow: 2px 2px 0 var(--ink);\n    }\n    .chip-mint { background: var(--mint); color: var(--ink); }\n    .chip-crimson { background: var(--crimson); color: var(--cream); }\n\n    /* Hand-drawn Input */\n    .ink-input-container {\n      position: relative;\n      margin: 1.5rem 0;\n    }\n    .ink-input {\n      width: 100%;\n      background: transparent;\n      border: none;\n      font-family: 'Fraunces', serif;\n      font-style: italic;\n      font-size: 1.125rem;\n      padding: 10px 40px 10px 0;\n      color: var(--ink);\n      outline: none;\n    }\n    .ink-input::placeholder { color: rgba(58, 44, 92, 0.3); }\n    .ink-line {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      width: 100%;\n      height: 4px;\n      background: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 400 4' preserveAspectRatio='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 2 Q 10 0, 20 2 T 40 2 T 60 2 T 80 2 T 100 2 T 120 2 T 140 2 T 160 2 T 180 2 T 200 2 T 220 2 T 240 2 T 260 2 T 280 2 T 300 2 T 320 2 T 340 2 T 360 2 T 380 2 T 400 2' stroke='%233A2C5C' stroke-width='2' fill='none'/%3E%3C/svg%3E\") repeat-x;\n      opacity: 0.6;\n    }\n\n    /* Scrollbar */\n    #results-list::-webkit-scrollbar { display: none; }\n    #results-list { -ms-overflow-style: none; scrollbar-width: none; }\n\n    /* Custom Animations Classes */\n    .pop-entry { transform-origin: center bottom; }\n\n    /* Marginalia Doodles */\n    .doodle {\n      position: absolute;\n      pointer-events: none;\n      opacity: 0.15;\n      z-index: 0;\n    }\n\n    /* Dots decorative */\n    .dots-divider {\n      background-image: radial-gradient(circle, var(--ink) 1px, transparent 1px);\n      background-size: 8px 8px;\n      background-repeat: repeat-x;\n      height: 8px;\n      opacity: 0.3;\n    }\n  </style>\n\n  \n  <header class=\"p-6 flex items-center justify-between relative z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-8 h-8 rounded-full bg-[#3A2C5C] flex items-center justify-center\" data-kid=\"4\">\n        <span class=\"font-display text-[#F4E9D0] font-bold\" data-kid=\"5\">L</span>\n      </div>\n      <span class=\"font-display font-black text-xl tracking-tight\" data-kid=\"6\">Lyrico</span>\n    </div>\n    <button class=\"w-10 h-10 rounded-full border-2 border-[#3A2C5C] flex items-center justify-center bg-[#E08244] shadow-[3px_3px_0_#3A2C5C] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all\" data-kid=\"7\">\n      <i class=\"ti ti-settings text-xl\" data-kid=\"8\"></i>\n    </button>\n  </header>\n\n  <main class=\"px-6 pb-40 overflow-y-auto max-h-[calc(100vh-80px)]\" id=\"main-content\" data-kid=\"9\">\n    \n    \n    <section class=\"mb-10 pt-4\" id=\"welcome-section\" data-kid=\"10\">\n      <div class=\"text-center mb-4\" data-kid=\"11\">\n        <span class=\"text-[10px] tracking-[0.3em] uppercase opacity-50 font-bold\" data-kid=\"12\">— Live on Widget —</span>\n      </div>\n      \n      <div class=\"relative max-w-[320px] mx-auto pop-entry\" id=\"widget-card\" data-kid=\"13\">\n        \n        <div class=\"washi -top-2 -left-3 rotate-[-12deg]\" data-kid=\"14\"></div>\n        <div class=\"washi -top-1 -right-4 rotate-[15deg]\" style=\"background: repeating-linear-gradient(45deg, rgba(168, 214, 184, 0.5) 0 6px, rgba(168, 214, 184, 0.3) 6px 12px);\" data-kid=\"15\"></div>\n        \n        <div class=\"relative bg-[#EFE0BE] p-6 cut-card fold-shadow border border-[#3A2C5C]/10\" data-kid=\"16\">\n          <div class=\"absolute inset-0 grain\" data-kid=\"17\"></div>\n          \n          <div class=\"relative z-10 flex gap-5 items-center\" data-kid=\"18\">\n            \n            <div class=\"w-24 h-28 bg-white border-2 border-[#3A2C5C] rotate-[-2deg] cut-card shrink-0 overflow-hidden fold-shadow\" data-kid=\"19\">\n               <img src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/a993fd29-0101-46bc-9b8b-13bc576c1070/98af5e4f49344c06ae10455cab032214.png\" class=\"w-full h-full object-cover scale-[1.2] translate-y-4 translate-x-1\" alt=\"Melodic Fox illustration\" decoding=\"async\" loading=\"lazy\" data-kid=\"20\">\n            </div>\n            \n            <div class=\"flex-1 space-y-1\" data-kid=\"21\">\n              <h2 class=\"font-display text-2xl font-black leading-none\" data-kid=\"22\">The Forest Waltz</h2>\n              <p class=\"font-display italic text-base opacity-70\" data-kid=\"23\">Melodic Fox</p>\n              <div class=\"pt-3 flex gap-2\" data-kid=\"24\">\n                <span class=\"chip chip-mint\" data-kid=\"25\">Synced</span>\n              </div>\n            </div>\n          </div>\n          \n          \n          <div class=\"absolute bottom-2 right-4 text-[9px] tracking-[0.2em] uppercase opacity-30 font-display italic\" data-kid=\"26\">\n            folio 042\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-8 relative\" data-kid=\"27\">\n      <div class=\"ink-input-container\" data-kid=\"28\">\n        <i class=\"ti ti-search absolute right-0 top-1/2 -translate-y-1/2 text-xl opacity-40\" data-kid=\"29\"></i>\n        <input type=\"text\" id=\"search-input\" class=\"ink-input\" placeholder=\"Summon a song title...\" data-kid=\"30\">\n        <div class=\"ink-line\" data-kid=\"31\"></div>\n      </div>\n      <div class=\"flex gap-8 mt-4\" data-kid=\"32\">\n        <button class=\"text-[10px] tracking-widest uppercase font-bold opacity-60 border-b-2 border-[#3A2C5C]/10 pb-1 hover:opacity-100 transition-opacity\" data-kid=\"33\">Popular scrolls</button>\n        <button class=\"text-[10px] tracking-widest uppercase font-bold opacity-60 border-b-2 border-[#3A2C5C]/10 pb-1 hover:opacity-100 transition-opacity\" data-kid=\"34\">Recently folded</button>\n      </div>\n    </section>\n\n    \n    <section id=\"results-section\" class=\"space-y-4\" data-kid=\"35\">\n      <div class=\"flex items-center gap-3 mb-6\" data-kid=\"36\">\n        <span class=\"font-display italic text-sm opacity-50\" data-kid=\"37\">Results from the library</span>\n        <div class=\"flex-1 dots-divider\" data-kid=\"38\"></div>\n      </div>\n      \n      \n      <div class=\"doodle top-[30%] -left-4\" data-kid=\"39\">\n        <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"currentColor\" data-kid=\"40\"><path d=\"M20 0L24 16L40 20L24 24L20 40L16 24L0 20L16 16L20 0Z\" data-kid=\"41\"></path></svg>\n      </div>\n      <div class=\"doodle top-[70%] -right-4\" data-kid=\"42\">\n        <svg width=\"30\" height=\"30\" viewBox=\"0 0 30 30\" fill=\"currentColor\" data-kid=\"43\"><circle cx=\"15\" cy=\"15\" r=\"10\" stroke=\"currentColor\" fill=\"none\" stroke-width=\"2\" stroke-dasharray=\"4 2\" data-kid=\"44\"></circle></svg>\n      </div>\n\n      <div class=\"space-y-5\" id=\"results-list\" data-kid=\"45\">\n        \n        <div class=\"flap-card p-5 rotate-[0.5deg] hover:rotate-0 hover:transition-shadow hover:duration-300 cursor-pointer result-item\" data-kid=\"46\">\n          <div class=\"flex justify-between items-start\" data-kid=\"47\">\n            <div class=\"space-y-1\" data-kid=\"48\">\n              <h3 class=\"font-display font-bold text-lg leading-tight\" data-kid=\"49\">Moonlight Sonata (Remix)</h3>\n              <p class=\"text-xs opacity-60\" data-kid=\"50\">Lunar Ensemble · Album: Night Skies</p>\n            </div>\n            <span class=\"chip chip-mint\" data-kid=\"51\">Synced</span>\n          </div>\n          <div class=\"mt-4 flex justify-between items-center border-t border-[#3A2C5C]/5 pt-3\" data-kid=\"52\">\n             <span class=\"text-[9px] font-bold uppercase tracking-widest opacity-40 italic-d\" data-kid=\"53\">4:12 duration</span>\n             <div class=\"flex items-center gap-2\" data-kid=\"54\">\n               <span class=\"text-[10px] font-bold text-[var(--pumpkin)] h-6 flex items-center\" data-kid=\"55\">VIEW SCROLL</span>\n               <i class=\"ti ti-arrow-narrow-right text-xl opacity-40 h-6 flex items-center\" data-kid=\"56\"></i>\n             </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flap-card p-5 rotate-[-1.2deg] hover:rotate-0 hover:transition-shadow hover:duration-300 cursor-pointer result-item bg-[#F4E9D0]\" style=\"clip-path: polygon(0% 2%, 99% 0.5%, 100% 25%, 98% 75%, 100% 98%, 2% 100%, 1% 45%);\" data-kid=\"57\">\n          <div class=\"flex justify-between items-start\" data-kid=\"58\">\n            <div class=\"space-y-1\" data-kid=\"59\">\n              <h3 class=\"font-display font-bold text-lg leading-tight\" data-kid=\"60\">Whispers in the Rain</h3>\n              <p class=\"text-xs opacity-60\" data-kid=\"61\">The Weeping Willows</p>\n            </div>\n            <span class=\"chip chip-crimson\" data-kid=\"62\">Plain</span>\n          </div>\n          <div class=\"mt-4 flex justify-between items-center border-t border-[#3A2C5C]/5 pt-3\" data-kid=\"63\">\n             <span class=\"text-[9px] font-bold uppercase tracking-widest opacity-40 italic-d\" data-kid=\"64\">2:58 duration</span>\n             <div class=\"flex items-center gap-2\" data-kid=\"65\">\n               <span class=\"text-[10px] font-bold text-[var(--pumpkin)] h-6 flex items-center\" data-kid=\"66\">VIEW SCROLL</span>\n               <i class=\"ti ti-arrow-narrow-right text-xl opacity-40 h-6 flex items-center\" data-kid=\"67\"></i>\n             </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flap-card p-5 rotate-[0.8deg] hover:rotate-0 hover:transition-shadow hover:duration-300 cursor-pointer result-item bg-[#EFE0BE]\" style=\"clip-path: polygon(2% 0%, 100% 2.5%, 99% 45%, 100% 92%, 97% 100%, 0% 98%, 1% 15%);\" data-kid=\"68\">\n          <div class=\"flex justify-between items-start\" data-kid=\"69\">\n            <div class=\"space-y-1\" data-kid=\"70\">\n              <h3 class=\"font-display font-bold text-lg leading-tight\" data-kid=\"71\">Gilded Pages</h3>\n              <p class=\"text-xs opacity-60\" data-kid=\"72\">Folio Quartet · Summer Almanac</p>\n            </div>\n            <span class=\"chip chip-mint\" data-kid=\"73\">Synced</span>\n          </div>\n          <div class=\"mt-4 flex justify-between items-center border-t border-[#3A2C5C]/5 pt-3\" data-kid=\"74\">\n             <span class=\"text-[9px] font-bold uppercase tracking-widest opacity-40 italic-d\" data-kid=\"75\">3:45 duration</span>\n             <div class=\"flex items-center gap-2\" data-kid=\"76\">\n               <span class=\"text-[10px] font-bold text-[var(--pumpkin)] h-6 flex items-center\" data-kid=\"77\">VIEW SCROLL</span>\n               <i class=\"ti ti-arrow-narrow-right text-xl opacity-40 h-6 flex items-center\" data-kid=\"78\"></i>\n             </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"empty-state\" class=\"hidden flex flex-col items-center justify-center py-20 text-center opacity-0\" data-kid=\"79\">\n      <div class=\"relative mb-8 pop-entry\" data-kid=\"80\">\n        \n        <div class=\"w-28 h-40 bg-[#C23D3D] rounded-r-xl border-2 border-[#3A2C5C] shadow-[10px_0_0_#3A2C5C,0_15px_30px_rgba(58,44,92,0.15)] relative flex items-center justify-center rotate-[-5deg]\" data-kid=\"81\">\n          <div class=\"absolute left-4 top-0 bottom-0 w-[2px] bg-[#3A2C5C]/20\" data-kid=\"82\"></div>\n          <div class=\"absolute left-5 top-0 bottom-0 w-[1px] bg-white/10\" data-kid=\"83\"></div>\n          \n          <div class=\"w-16 h-20 border border-white/20 rounded flex flex-col items-center justify-center gap-2 p-2\" data-kid=\"84\">\n            <div class=\"w-10 h-[1px] bg-white/20\" data-kid=\"85\"></div>\n            <span class=\"font-display text-white italic text-[10px] uppercase tracking-widest\" data-kid=\"86\">Lyrico</span>\n            <div class=\"w-10 h-[1px] bg-white/20\" data-kid=\"87\"></div>\n          </div>\n          \n          \n          <div class=\"absolute -top-3 -right-4 text-[#E08244] animate-bounce\" data-kid=\"88\">\n            <svg class=\"w-8 h-8\" viewBox=\"0 0 24 24\" fill=\"currentColor\" data-kid=\"89\"><path d=\"M12,2L14.85,8.65L22,9.24L16.5,13.97L18.18,21L12,17.27L5.82,21L7.5,13.97L2,9.24L9.15,8.65L12,2Z\" data-kid=\"90\"></path></svg>\n          </div>\n        </div>\n      </div>\n      \n      <h3 class=\"font-display text-2xl font-black mb-3\" data-kid=\"91\">Quiet in the Library</h3>\n      <p class=\"italic-d text-base opacity-60 max-w-[240px] leading-snug\" data-kid=\"92\">\n        It seems that particular song hasn't been written in our scrolls yet.\n      </p>\n      \n      <button id=\"retry-btn\" class=\"mt-8 px-6 py-3 bg-[#E08244] border-2 border-[#3A2C5C] shadow-[4px_4px_0_#3A2C5C] rounded-full font-bold text-sm flex items-center gap-2 active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all\" data-kid=\"93\">\n        <i class=\"ti ti-refresh text-lg\" data-kid=\"94\"></i> Search Again\n      </button>\n    </section>\n\n  </main>\n\n  \n  <footer class=\"fixed bottom-0 left-0 right-0 p-6 bg-transparent pointer-events-none flex justify-center z-[100]\" data-kid=\"95\">\n    <div class=\"bg-[#F4E9D0] border-2 border-[#3A2C5C] rounded-[24px_16px_22px_18px] p-2 flex gap-2 shadow-[0_12px_30px_rgba(58,44,92,0.2)] pointer-events-auto overflow-hidden relative rotate-[-0.5deg]\" data-kid=\"96\">\n      <div class=\"absolute inset-0 grain opacity-15\" data-kid=\"97\"></div>\n      <button class=\"w-14 h-14 rounded-[18px_12px_15px_10px] flex items-center justify-center bg-[#3A2C5C] text-[#F4E9D0] shadow-[inset_2px_2px_0_rgba(0,0,0,0.3)]\" title=\"Search\" data-kid=\"98\">\n        <i class=\"ti ti-search text-2xl\" data-kid=\"99\"></i>\n      </button>\n      <button class=\"w-14 h-14 rounded-[12px_18px_10px_15px] flex items-center justify-center hover:bg-[#3A2C5C]/5\" title=\"Library\" data-kid=\"100\">\n        <i class=\"ti ti-book-2 text-2xl\" data-kid=\"101\"></i>\n      </button>\n      <button class=\"w-14 h-14 rounded-[15px_10px_18px_12px] flex items-center justify-center hover:bg-[#3A2C5C]/5\" title=\"Home\" data-kid=\"102\">\n        <i class=\"ti ti-smart-home text-2xl\" data-kid=\"103\"></i>\n      </button>\n    </div>\n  </footer>\n\n  \n  <div class=\"fixed bottom-32 right-6 z-[110] opacity-0\" id=\"floating-satchel\" data-kid=\"104\">\n    <button class=\"relative w-16 h-16 bg-[#E08244] border-2 border-[#3A2C5C] shadow-[4px_4px_0_#3A2C5C] rounded-xl flex flex-col items-center justify-center overflow-hidden active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all group\" data-kid=\"105\">\n       <div class=\"absolute top-0 left-0 w-full h-3 bg-[#c46a30] border-b border-[#3A2C5C]/20\" data-kid=\"106\"></div>\n       <i class=\"ti ti-shopping-bag text-2xl mt-1\" data-kid=\"107\"></i>\n       <span class=\"absolute -top-1 -right-1 w-6 h-6 bg-[#C23D3D] border-2 border-[#3A2C5C] text-white text-[10px] font-black flex items-center justify-center rounded-full\" data-kid=\"108\">3</span>\n    </button>\n  </div>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"109\"></script>\n  <script data-kid=\"110\">\n    document.addEventListener('DOMContentLoaded', () => {\n      // Entrance Animations\n      gsap.from('#widget-card', {\n        y: 50,\n        opacity: 0,\n        rotate: -5,\n        duration: 1.2,\n        ease: 'elastic.out(1, 0.75)',\n        delay: 0.2\n      });\n\n      gsap.from('.result-item', {\n        y: 30,\n        opacity: 0,\n        rotateX: -30,\n        duration: 0.8,\n        stagger: 0.1,\n        ease: 'back.out(1.7)',\n        delay: 0.5\n      });\n\n      gsap.from('.ink-line', {\n        scaleX: 0,\n        duration: 1,\n        ease: 'power4.out',\n        delay: 0.4\n      });\n\n      gsap.to('#floating-satchel', {\n        opacity: 1,\n        y: 0,\n        startAt: { y: 20 },\n        duration: 0.6,\n        delay: 1.2,\n        ease: 'back.out(2)'\n      });\n\n      // Simple Search Simulation\n      const searchInput = document.getElementById('search-input');\n      const resultsSection = document.getElementById('results-section');\n      const emptyState = document.getElementById('empty-state');\n      const retryBtn = document.getElementById('retry-btn');\n\n      searchInput.addEventListener('keypress', (e) => {\n        if (e.key === 'Enter') {\n          const query = searchInput.value.toLowerCase();\n          \n          gsap.to([resultsSection, '#welcome-section'], {\n            opacity: 0,\n            y: -20,\n            duration: 0.4,\n            onComplete: () => {\n              resultsSection.classList.add('hidden');\n              document.getElementById('welcome-section').classList.add('hidden');\n              \n              if (query === 'none' || query === 'empty') {\n                showEmptyState();\n              } else {\n                showResults();\n              }\n            }\n          });\n        }\n      });\n\n      function showEmptyState() {\n        emptyState.classList.remove('hidden');\n        gsap.to(emptyState, {\n          opacity: 1,\n          y: 0,\n          duration: 0.6,\n          ease: 'power3.out'\n        });\n        gsap.from('#empty-state .pop-entry', {\n          scale: 0.8,\n          rotate: -10,\n          duration: 1,\n          ease: 'elastic.out(1, 0.5)'\n        });\n      }\n\n      function showResults() {\n        resultsSection.classList.remove('hidden');\n        gsap.to(resultsSection, {\n          opacity: 1,\n          y: 0,\n          duration: 0.4\n        });\n      }\n\n      retryBtn.addEventListener('click', () => {\n        gsap.to(emptyState, {\n          opacity: 0,\n          duration: 0.3,\n          onComplete: () => {\n            emptyState.classList.add('hidden');\n            document.getElementById('welcome-section').classList.remove('hidden');\n            resultsSection.classList.remove('hidden');\n            gsap.to([resultsSection, '#welcome-section'], { opacity: 1, y: 0, duration: 0.5 });\n            searchInput.value = '';\n          }\n        });\n      });\n    });\n  </script>\n</div>\n",
