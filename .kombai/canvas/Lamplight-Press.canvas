      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n  --mint: #A8D6B8;\n  --crimson: #C23D3D;\n  --ink: #3A2C5C;\n  --cream: #F4E9D0;\n  --pumpkin: #E08244;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  background-color: #f0f0f0;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  min-height: 100vh;\n  font-family: 'Inter', sans-serif;\n}\n\n/* Paper Texture */\n.paper-mint {\n  background-color: var(--mint);\n  background-image: \n    radial-gradient(rgba(58, 44, 92, 0.08) 1.5px, transparent 1.5px);\n  background-size: 20px 20px;\n  position: relative;\n  overflow: hidden;\n  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);\n  border: 3px solid var(--ink);\n}\n\n.grain::before {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n  opacity: 0.3;\n  mix-blend-mode: multiply;\n  background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n}\n\n.paper-crimson {\n  background-color: var(--crimson);\n  background-image: radial-gradient(rgba(244, 233, 208, 0.15) 1px, transparent 1px);\n  background-size: 12px 12px;\n}\n\n/* Typography Classes */\n.font-display { font-family: 'Fraunces', serif; }\n.font-body { font-family: 'Inter', sans-serif; }\n\n/* Hand-cut Shapes */\n.cut-card {\n  clip-path: polygon(1% 2%, 98% 0%, 100% 97%, 2% 100%);\n}\n\n.cut-active {\n  color: var(--cream);\n  clip-path: polygon(0.5% 3%, 99% 1%, 100% 97%, 1% 100%);\n  transform: rotate(-0.5deg);\n}\n\n/* Washi Tape */\n.washi {\n  position: absolute;\n  height: 28px;\n  width: 140px;\n  background: repeating-linear-gradient(45deg, rgba(224, 130, 68, 0.7) 0 10px, rgba(224, 130, 68, 0.5) 10px 20px);\n  border-left: 1px dashed rgba(58, 44, 92, 0.3);\n  border-right: 1px dashed rgba(58, 44, 92, 0.3);\n  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 10px;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  font-weight: 700;\n  color: var(--ink);\n  z-index: 10;\n}\n\n/* Buttons */\n.btn-tactile {\n  background: var(--cream);\n  border: 2px solid var(--ink);\n  box-shadow: 4px 4px 0 var(--ink);\n  transition: all 0.1s ease;\n  clip-path: polygon(4% 8%, 96% 2%, 99% 94%, 2% 98%);\n}\n\n.btn-tactile:active {\n  transform: translate(2px, 2px);\n  box-shadow: 2px 2px 0 var(--ink);\n}\n\n.btn-crimson {\n  background: var(--crimson);\n  color: var(--cream);\n  clip-path: polygon(2% 4%, 98% 6%, 96% 96%, 4% 94%);\n}\n\n/* Dotted Divider */\n.dotted {\n  background-image: radial-gradient(circle, var(--ink) 1.5px, transparent 1.5px);\n  background-size: 12px 12px;\n  background-repeat: repeat-x;\n  background-position: center;\n  height: 12px;\n  opacity: 0.4;\n}\n\n/* Animation utilities */\n.lyric-item {\n  opacity: 0.6;\n}\n.lyric-item.active {\n  opacity: 1;\n}\n\n</style>\n\n<div class=\"paper-mint w-[375px] h-[667px] p-0 flex flex-col grain rounded-[40px] border-[12px] border-[var(--ink)] select-none overflow-hidden\" data-kid=\"1\">\n  \n  \n  <header class=\"pt-10 pb-6 px-8 relative\" data-kid=\"2\">\n    <div class=\"washi top-4 left-1/2 -translate-x-1/2 -rotate-2\" data-kid=\"3\">SYNCED LYRICS</div>\n    \n    <div class=\"text-center space-y-1 mt-4\" data-kid=\"4\">\n      <h1 class=\"font-display text-2xl font-black text-[var(--ink)] leading-tight tracking-tight uppercase\" data-kid=\"5\">\n        Starman\n      </h1>\n      <p class=\"font-display italic text-base text-[var(--ink)]/60\" data-kid=\"6\">David Bowie</p>\n    </div>\n    \n    <div class=\"dotted mt-6\" data-kid=\"7\"></div>\n  </header>\n\n  \n  <main class=\"flex-1 flex flex-col justify-center px-4 overflow-hidden relative\" data-kid=\"8\">\n    \n    <div class=\"lyric-item py-6 text-center opacity-60\" data-kid=\"9\">\n      <p class=\"font-display text-xl text-[var(--ink)] font-medium italic leading-snug\" data-kid=\"10\">\n        There's a starman waiting in the sky\n      </p>\n    </div>\n\n    \n    <div class=\"relative py-4 w-full px-2\" data-kid=\"11\">\n      <div class=\"cut-active paper-crimson py-6 px-4 text-center z-10 relative border-2 border-[var(--ink)] shadow-[6px_6px_0_var(--ink)]\" data-kid=\"12\">\n        <p class=\"font-display text-[24px] font-black italic leading-tight tracking-tight drop-shadow-[0_1px_1px_rgba(58,44,92,0.3)]\" data-kid=\"13\">\n          He'd like to come and meet us\n        </p>\n      </div>\n      \n      <div class=\"absolute inset-0 bg-[var(--ink)]/10 translate-x-3 translate-y-3 rounded-xl -rotate-2 pointer-events-none\" data-kid=\"14\"></div>\n    </div>\n\n    \n    <div class=\"lyric-item py-6 text-center opacity-60\" data-kid=\"15\">\n      <p class=\"font-display text-xl text-[var(--ink)] font-medium italic leading-snug\" data-kid=\"16\">\n        But he thinks he'd blow our minds\n      </p>\n    </div>\n    <div class=\"lyric-item py-4 text-center opacity-25\" data-kid=\"17\">\n      <p class=\"font-display text-lg text-[var(--ink)] font-medium italic leading-snug\" data-kid=\"18\">\n        There's a starman waiting in the sky\n      </p>\n    </div>\n  </main>\n\n  \n  <footer class=\"pb-12 pt-4 px-8 relative\" data-kid=\"19\">\n    <div class=\"dotted mb-8\" data-kid=\"20\"></div>\n    \n    <div class=\"flex items-center justify-between gap-4\" data-kid=\"21\">\n      <button class=\"btn-tactile w-[68px] h-[68px] flex items-center justify-center cursor-pointer\" aria-label=\"Previous line\" data-kid=\"22\">\n        <i class=\"ti ti-arrow-back-up text-[var(--ink)] text-3xl relative left-[1px]\" data-kid=\"23\"></i>\n      </button>\n\n      <button class=\"btn-tactile btn-crimson w-[84px] h-[84px] flex items-center justify-center cursor-pointer group\" aria-label=\"Play/Pause\" data-kid=\"24\">\n        <i class=\"ti ti-player-pause-filled text-4xl group-active:scale-90 transition-transform relative top-[-1px]\" data-kid=\"25\"></i>\n      </button>\n\n      <button class=\"btn-tactile w-[68px] h-[68px] flex items-center justify-center cursor-pointer\" aria-label=\"Next line\" data-kid=\"26\">\n        <i class=\"ti ti-player-skip-forward-filled text-[var(--ink)] text-3xl relative left-[1px]\" data-kid=\"27\"></i>\n      </button>\n    </div>\n    \n    <div class=\"mt-8 flex justify-center\" data-kid=\"28\">\n      <div class=\"bg-[var(--ink)]/15 px-4 py-1.5 rounded-full flex items-center gap-2 border border-[var(--ink)]/10\" data-kid=\"29\">\n        <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--crimson)] animate-pulse shadow-[0_0_4px_var(--crimson)]\" data-kid=\"30\"></span>\n        <span class=\"text-[10px] font-bold tracking-widest text-[var(--ink)]/70 uppercase font-body\" data-kid=\"31\">Sync Active</span>\n      </div>\n    </div>\n  </footer>\n\n  \n  <div class=\"absolute -bottom-2 -right-2 w-20 h-20 bg-[var(--cream)] border-2 border-[var(--ink)] rounded-full flex flex-col items-center justify-center rotate-12 shadow-md pointer-events-none z-20\" data-kid=\"32\">\n    <span class=\"font-display font-black text-[10px] text-[var(--ink)] text-center leading-none uppercase tracking-tighter\" data-kid=\"33\">Original</span>\n    <span class=\"font-display font-black text-[14px] text-[var(--ink)] text-center leading-none uppercase\" data-kid=\"34\">Press</span>\n  </div>\n</div>\n\n<script type=\"module\" data-kid=\"35\">\n  import { animate, spring, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Entrance animations\n  animate(\".cut-active\", { scale: [0.85, 1], opacity: [0, 1], rotate: [-4, -0.5] }, { duration: 0.8, ease: spring() });\n  \n  // Staggered appearance for lyrics\n  animate(\".lyric-item\", { y: [20, 0], opacity: [0, (el) => parseFloat(window.getComputedStyle(el).opacity)] }, { \n    duration: 1, \n    delay: stagger(0.1, { startDelay: 0.4 })\n  });\n\n  // Staggered buttons\n  animate(\".btn-tactile\", { y: [40, 0], opacity: [0, 1] }, { \n    duration: 0.7, \n    delay: stagger(0.1, { startDelay: 0.6 }),\n    ease: spring({ stiffness: 100, damping: 10 })\n  });\n</script>\n",
