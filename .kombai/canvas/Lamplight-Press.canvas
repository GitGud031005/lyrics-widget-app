      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --lp-cream: #F4E9D0;\n    --lp-cream2: #EFE0BE;\n    --lp-ink: #3A2C5C;\n    --lp-pumpkin: #E08244;\n    --lp-mint: #A8D6B8;\n    --lp-crimson: #C23D3D;\n  }\n\n  body {\n    background-color: var(--lp-cream);\n    color: var(--lp-ink);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-display { font-family: 'Fraunces', serif; }\n\n  .paper-grain {\n    background-image: radial-gradient(var(--lp-ink) 1px, transparent 1px);\n    background-size: 20px 20px;\n    opacity: 0.03;\n  }\n\n  .paper-cut {\n    clip-path: polygon(1% 2%, 8% 0%, 22% 3%, 45% 1%, 70% 2%, 88% 0%, 99% 3%, 100% 18%, 98% 40%, 100% 62%, 99% 82%, 100% 97%, 84% 100%, 60% 98%, 36% 100%, 14% 99%, 2% 100%, 0% 80%, 2% 55%, 0% 30%, 1% 12%);\n  }\n\n  .dotted-divider {\n    background-image: radial-gradient(circle, var(--lp-ink) 1.5px, transparent 1.5px);\n    background-size: 12px 12px;\n    background-repeat: repeat-x;\n    background-position: center;\n    height: 12px;\n  }\n\n  .paper-shadow {\n    box-shadow: 0 10px 18px -8px rgba(58, 44, 92, 0.35), 0 4px 0 rgba(58, 44, 92, 0.2);\n  }\n\n  .washi-tape {\n    background: repeating-linear-gradient(45deg, rgba(224, 130, 68, 0.25) 0 8px, rgba(224, 130, 68, 0.15) 8px 16px);\n    border-left: 1px dashed rgba(58, 44, 92, 0.1);\n    border-right: 1px dashed rgba(58, 44, 92, 0.1);\n  }\n</style>\n\n<div class=\"min-h-screen relative flex flex-col\" data-kid=\"1\">\n  \n  <div class=\"fixed inset-0 paper-grain pointer-events-none\" data-kid=\"2\"></div>\n\n  \n  <header class=\"sticky top-0 z-50 bg-[var(--lp-cream)]/95 backdrop-blur-xs pt-4 pb-2 border-b border-[var(--lp-ink)]/5\" data-kid=\"3\">\n    <div class=\"px-6 flex flex-col items-center text-center\" data-kid=\"4\">\n      <h1 class=\"font-display text-lg font-black tracking-widest leading-tight uppercase\" data-kid=\"5\">Lyrico & Verse</h1>\n      <p class=\"text-[8px] tracking-[0.2em] opacity-60 uppercase font-medium\" data-kid=\"6\">manual lyrics widget · est. 2025</p>\n    </div>\n    \n    <div class=\"mt-4 px-6\" data-kid=\"7\">\n      <div class=\"flex items-center justify-between text-[11px] tracking-widest opacity-90 italic font-display\" data-kid=\"8\">\n        <span data-kid=\"9\">— find your voice, dear reader —</span>\n        <span class=\"not-italic font-sans text-[9px] font-bold opacity-60\" data-kid=\"10\">VOL. I</span>\n      </div>\n    </div>\n    \n    <div class=\"dotted-divider mt-2 opacity-30\" data-kid=\"11\"></div>\n  </header>\n\n  <main class=\"flex-1 overflow-y-auto pb-10\" data-kid=\"12\">\n    \n    <div class=\"px-4 pt-6 pb-4\" data-kid=\"13\">\n      <div class=\"paper-cut bg-[var(--lp-ink)]/5 border border-[var(--lp-ink)]/20 p-4 flex items-center gap-3\" data-kid=\"14\">\n        <i class=\"ti ti-pencil-line text-lg opacity-70\" data-kid=\"15\"></i>\n        <span class=\"text-[var(--lp-ink)]/70 text-sm font-medium\" data-kid=\"16\">Search song or artist...</span>\n        <div class=\"ml-auto w-4 h-4 rounded-full bg-[var(--lp-ink)]/10 flex items-center justify-center\" data-kid=\"17\">\n          <i class=\"ti ti-x text-[8px] font-black\" data-kid=\"18\"></i>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex flex-col items-center px-6 pt-2\" data-kid=\"19\">\n      \n      <div class=\"relative w-full aspect-[3/4] max-w-[280px]\" data-kid=\"20\">\n        <div class=\"absolute inset-0 paper-cut bg-[var(--lp-mint)]/40 paper-shadow translate-y-2 translate-x-1\" data-kid=\"21\"></div>\n        <div class=\"absolute inset-0 paper-cut bg-white border-2 border-[var(--lp-ink)] overflow-hidden\" data-kid=\"22\">\n          <img src=\"https://kombai-assets.b-cdn.net/generated_assets/546bcd6a-ae6d-45c1-85a6-b370c2cc2f99/7faea13a823a42299a4a3a537ac4b85b.jpg\" class=\"w-full h-full object-cover\" alt=\"Melodic Fox\" decoding=\"async\" loading=\"lazy\" data-kid=\"23\">\n        </div>\n      </div>\n\n      <div class=\"mt-8 text-center space-y-4\" data-kid=\"24\">\n        <h2 class=\"font-display text-3xl font-black leading-[0.9] text-[var(--lp-ink)]\" data-kid=\"25\">\n          Stories that<br data-kid=\"26\">unfold in the dark.\n        </h2>\n        \n        <div class=\"space-y-2\" data-kid=\"27\">\n          <p class=\"font-display italic text-base font-medium opacity-80\" data-kid=\"28\">A glanceable viewport for your Home Screen.</p>\n          <p class=\"text-xs opacity-60 leading-relaxed max-w-[240px] mx-auto\" data-kid=\"29\">Step through lyrics line-by-line with interactive controls.</p>\n        </div>\n      </div>\n\n      \n      <div class=\"mt-8 w-full relative\" data-kid=\"30\">\n        <div class=\"absolute inset-0 washi-tape rotate-[-1.5deg]\" data-kid=\"31\"></div>\n        <div class=\"relative py-4 px-6 text-center\" data-kid=\"32\">\n          <p class=\"text-[8px] font-black tracking-widest opacity-40 uppercase mb-1\" data-kid=\"33\">Currently on Widget</p>\n          <p class=\"font-display text-sm font-bold text-[var(--lp-crimson)]\" data-kid=\"34\">Bohemian Rhapsody — Queen</p>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-10 px-4 space-y-6\" data-kid=\"35\">\n       <div class=\"dotted-divider opacity-20\" data-kid=\"36\"></div>\n       \n       <h3 class=\"text-[10px] font-black tracking-widest opacity-40 uppercase px-2 mb-2\" data-kid=\"37\">Recently Unfolded</h3>\n\n       \n       <div class=\"relative group\" data-kid=\"38\">\n         <div class=\"paper-cut bg-white/60 border border-[var(--lp-ink)]/10 p-4 pl-16 paper-shadow flex items-center justify-between\" data-kid=\"39\">\n           \n           <div class=\"absolute left-0 top-0 bottom-0 w-12 bg-[var(--lp-mint)] rounded-l-md shadow-inner flex items-start justify-center pt-1\" data-kid=\"40\">\n             <div class=\"w-2 h-5 bg-[var(--lp-crimson)]\" data-kid=\"41\"></div>\n           </div>\n           \n           <div class=\"flex flex-col\" data-kid=\"42\">\n             <span class=\"font-display text-base font-bold\" data-kid=\"43\">Purple Rain</span>\n             <span class=\"text-xs opacity-70 font-medium\" data-kid=\"44\">Prince</span>\n           </div>\n           \n           <div class=\"flex flex-col items-end gap-1\" data-kid=\"45\">\n             <span class=\"text-[8px] font-black bg-[var(--lp-mint)] px-2 py-1 rounded border border-[var(--lp-ink)] uppercase\" data-kid=\"46\">Synced</span>\n             <span class=\"text-[9px] font-mono opacity-50\" data-kid=\"47\">8:41</span>\n           </div>\n         </div>\n       </div>\n\n       \n       <div class=\"relative group\" data-kid=\"48\">\n         <div class=\"paper-cut bg-white/60 border border-[var(--lp-ink)]/10 p-4 pl-16 paper-shadow flex items-center justify-between\" data-kid=\"49\">\n           \n           <div class=\"absolute left-0 top-0 bottom-0 w-12 bg-[var(--lp-pumpkin)] rounded-l-md shadow-inner flex items-start justify-center pt-1\" data-kid=\"50\">\n             <div class=\"w-2 h-5 bg-[var(--lp-crimson)]\" data-kid=\"51\"></div>\n           </div>\n           \n           <div class=\"flex flex-col\" data-kid=\"52\">\n             <span class=\"font-display text-base font-bold\" data-kid=\"53\">Imagine</span>\n             <span class=\"text-xs opacity-70 font-medium\" data-kid=\"54\">John Lennon</span>\n           </div>\n           \n           <div class=\"flex flex-col items-end gap-1\" data-kid=\"55\">\n             <span class=\"text-[9px] font-mono opacity-50\" data-kid=\"56\">3:03</span>\n           </div>\n         </div>\n       </div>\n    </div>\n  </main>\n</div>",
      "comments": [],
      "created": "2026-07-03T03:16:39.013926+00:00",
      "modified": "2026-07-03T03:47:17.128633+00:00",
