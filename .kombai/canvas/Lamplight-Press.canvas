 style=\"clip-path: polygon(4% 3%, 50% 0, 96% 4%, 100% 50%, 97% 96%, 50% 100%, 4% 96%, 0 50%);\" data-kid=\"358\">\n              <img src=\"https://kombai-assets.b-cdn.net/generated_assets/546bcd6a-ae6d-45c1-85a6-b370c2cc2f99/dae50d3d9be34dcbad3590153cbfb16f.jpg\" class=\"w-full h-full object-cover\" alt=\"Newsletter Image\" data-kid=\"359\">\n            </div>\n            <div class=\"absolute -bottom-3 -left-3 px-4 py-2 bg-[var(--crimson)] text-[var(--cream)] border-2 border-[var(--ink)] font-display italic-d rotate-[-5deg]\" data-kid=\"360\">issue 02</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"relative paper-ink text-[var(--cream)] pt-20 pb-10 px-8 mt-2\" data-kid=\"361\">\n    <div class=\"absolute -top-5 left-0 right-0 h-5 paper-ink scallop-top\" data-kid=\"362\"></div>\n    <div class=\"absolute inset-0 grain opacity-40\" data-kid=\"363\"></div>\n    <div class=\"max-w-[1280px] mx-auto relative\" data-kid=\"364\">\n      <div class=\"grid grid-cols-12 gap-10 pb-12\" data-kid=\"365\">\n        <div class=\"col-span-4\" data-kid=\"366\">\n          <div class=\"flex items-center gap-3 mb-5\" data-kid=\"367\">\n            <div class=\"w-12 h-12 rounded-full bg-[var(--cream)] flex items-center justify-center\" data-kid=\"368\">\n              <span class=\"font-display text-2xl italic font-bold text-[var(--ink)]\" data-kid=\"369\">L</span>\n            </div>\n            <div class=\"font-display text-2xl font-bold\" data-kid=\"370\">Lyrico &amp; Verse</div>\n          </div>\n          <p class=\"font-display italic text-lg leading-snug text-[var(--cream)]/80 max-w-xs\" data-kid=\"371\">\n            An independent app bringing the tactile beauty of typography to your modern music experience.\n          </p>\n          <div class=\"mt-6 flex items-center gap-3\" data-kid=\"372\">\n            <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" href=\"#\" data-kid=\"373\"><i class=\"ti ti-brand-instagram\" data-kid=\"374\"></i></a>\n            <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" href=\"#\" data-kid=\"375\"><i class=\"ti ti-brand-x\" data-kid=\"376\"></i></a>\n            <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" href=\"#\" data-kid=\"377\"><i class=\"ti ti-brand-pinterest\" data-kid=\"378\"></i></a>\n            <a class=\"w-10 h-10 rounded-full border border-[var(--cream)]/50 flex items-center justify-center\" href=\"#\" data-kid=\"379\"><i class=\"ti ti-rss\" data-kid=\"380\"></i></a>\n          </div>\n        </div>\n\n        <div class=\"col-span-2\" data-kid=\"381\">\n          <div class=\"text-[11px] tracking-[.3em] uppercase opacity-70 mb-4\" data-kid=\"382\">Explore</div>\n          <ul class=\"space-y-2 text-sm\" data-kid=\"383\">\n            <li data-kid=\"384\"><a href=\"#\" data-kid=\"385\">Library</a></li>\n            <li data-kid=\"386\"><a href=\"#\" data-kid=\"387\">Top Charts</a></li>\n            <li data-kid=\"388\"><a href=\"#\" data-kid=\"389\">The Verse Blog</a></li>\n            <li data-kid=\"390\"><a href=\"#\" data-kid=\"391\">Widget Mockups</a></li>\n            <li data-kid=\"392\"><a href=\"#\" data-kid=\"393\">Premium Plans</a></li>\n          </ul>\n        </div>\n        <div class=\"col-span-2\" data-kid=\"394\">\n          <div class=\"text-[11px] tracking-[.3em] uppercase opacity-70 mb-4\" data-kid=\"395\">Support</div>\n          <ul class=\"space-y-2 text-sm\" data-kid=\"396\">\n            <li data-kid=\"397\"><a href=\"#\" data-kid=\"398\">Setup Guide</a></li>\n            <li data-kid=\"399\"><a href=\"#\" data-kid=\"400\">Widget Help</a></li>\n            <li data-kid=\"401\"><a href=\"#\" data-kid=\"402\">Theme Lab</a></li>\n            <li data-kid=\"403\"><a href=\"#\" data-kid=\"404\">Press Kit</a></li>\n            <li data-kid=\"405\"><a href=\"#\" data-kid=\"406\">Contact Us</a></li>\n          </ul>\n        </div>\n        <div class=\"col-span-4\" data-kid=\"407\">\n          <div class=\"text-[11px] tracking-[.3em] uppercase opacity-70 mb-4\" data-kid=\"408\">Visit our studio</div>\n          <div class=\"font-display italic text-xl leading-snug\" data-kid=\"409\">\n            88 Music Row, Nashville, TN 37203<br data-kid=\"410\">\n            42 Melody Lane, Austin, TX 78701\n          </div>\n          <div class=\"mt-4 text-sm opacity-80\" data-kid=\"411\">hello@lyrico.verse · +1 888 555 0101</div>\n        </div>\n      </div>\n\n      <div class=\"dotted\" style=\"background-image: radial-gradient(circle, var(--cream) 1.5px, transparent 1.5px);\" data-kid=\"412\"></div>\n\n      <div class=\"flex flex-col items-center text-center mt-10 gap-4\" data-kid=\"413\">\n        <div class=\"w-14 h-14 rounded-full bg-[var(--cream)] flex items-center justify-center relative\" data-kid=\"414\">\n          <span class=\"font-display text-3xl italic font-bold text-[var(--ink)]\" data-kid=\"415\">L</span>\n          <i class=\"ti ti-music-note absolute -top-1 -right-1 text-xl text-[var(--crimson)]\" data-kid=\"416\"></i>\n        </div>\n        <nav class=\"flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm\" data-kid=\"417\">\n          <a href=\"#\" data-kid=\"418\">Search</a><a href=\"#\" data-kid=\"419\">Widget</a><a href=\"#\" data-kid=\"420\">Themes</a><a href=\"#\" data-kid=\"421\">Setup</a><a href=\"#\" data-kid=\"422\">Premium</a><a href=\"#\" data-kid=\"423\">Contact</a>\n        </nav>\n        <div class=\"text-xs opacity-60 mt-3 font-display italic\" data-kid=\"424\">\n          © 2025 Lyrico &amp; Verse. Crafted with love for lyrics. Apple, the Apple logo, and iPhone are trademarks of Apple Inc.\n        </div>\n      </div>\n    </div>\n  </footer>\n\n  \n  <div class=\"fixed bottom-8 right-8 z-50\" data-kid=\"425\">\n    <button class=\"satchel w-20 h-20 flex items-center justify-center relative hover:scale-105 transition-transform\" data-kid=\"426\">\n      <div class=\"satchel-flap\" data-kid=\"427\"></div>\n      <i class=\"ti ti-music text-3xl text-[var(--ink)] relative z-10\" data-kid=\"428\"></i>\n      <span class=\"absolute -top-1 -right-1 w-7 h-7 rounded-full bg-[var(--crimson)] border-2 border-[var(--ink)] text-[var(--cream)] font-display font-bold text-sm flex items-center justify-center\" data-kid=\"429\">12</span>\n    </button>\n  </div>\n\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"430\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"431\"></script>\n<script data-kid=\"432\">\n  gsap.registerPlugin(ScrollTrigger);\n  const paperEase = \"elastic.out(1, 0.6)\";\n\n  gsap.utils.toArray('.pop-up').forEach(el => {\n    gsap.from(el, {\n      scale: 0.4,\n      y: 60,\n      rotate: -6,\n      opacity: 0,\n      duration: 1.2,\n      ease: paperEase,\n      scrollTrigger: { trigger: el, start: 'top 85%' }\n    });\n  });\n\n  gsap.utils.toArray('.flap-card').forEach((el, i) => {\n    gsap.from(el, {\n      y: 40,\n      opacity: 0,\n      rotateX: -40,\n      transformOrigin: 'top center',\n      duration: 0.8,\n      ease: 'back.out(1.6)',\n      delay: i * 0.05,\n      scrollTrigger: { trigger: el, start: 'top 90%' }\n    });\n  });\n\n  gsap.utils.toArray('.spine-book').forEach((el, i) => {\n    gsap.from(el, {\n      y: 80,\n      opacity: 0,\n      duration: 0.6,\n      delay: i * 0.04,\n      ease: 'power3.out',\n      scrollTrigger: { trigger: el, start: 'top 95%' }\n    });\n  });\n\n  gsap.utils.toArray('.bubble').forEach(el => {\n    gsap.from(el, {\n      scale: 0.6,\n      opacity: 0,\n      duration: 0.7,\n      ease: 'back.out(2)',\n      scrollTrigger: { trigger: el, start: 'top 88%' }\n    });\n  });\n</script>\n",
      "comments": [],
      "created": "2026-07-02T09:32:08.745774+00:00",
