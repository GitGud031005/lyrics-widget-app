      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,400;1,9..144,600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');\n\n  :root {\n    --cream: #F4E9D0;\n    --cream-2: #EFE0BE;\n    --ink: #3A2C5C;\n    --pumpkin: #E08244;\n    --mint: #A8D6B8;\n    --crimson: #C23D3D;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n    background-color: #f0f0f0;\n    font-family: 'Inter', sans-serif;\n  }\n\n  /* Paper textures from Lamplight Press */\n  .paper {\n    background-color: var(--cream);\n    background-image:\n      radial-gradient(rgba(58, 44, 92, 0.06) 1px, transparent 1px),\n      radial-gradient(rgba(192, 140, 80, 0.08) 1px, transparent 1px);\n    background-size: 18px 18px, 6px 6px;\n    background-position: 0 0, 2px 2px;\n    position: relative;\n  }\n\n  .grain::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0.3;\n    mix-blend-mode: multiply;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\");\n  }\n\n  /* Hand-cut clip path - simplified for 148pt scale */\n  .cut-card {\n    clip-path: polygon(0% 2%, 40% 0%, 80% 1%, 100% 0%, 98% 30%, 100% 70%, 99% 98%, 60% 100%, 20% 99%, 0% 100%, 2% 70%, 1% 30%);\n  }\n\n  /* Washi tape highlight - more vibrant and slightly longer */\n  .washi {\n    background: repeating-linear-gradient(45deg, rgba(224, 130, 68, 0.5) 0 6px, rgba(224, 130, 68, 0.4) 6px 12px);\n    border-left: 1px dashed rgba(58, 44, 92, 0.3);\n    border-right: 1px dashed rgba(58, 44, 92, 0.3);\n    box-shadow: 0 2px 4px rgba(58, 44, 92, 0.1);\n    transform: rotate(-1.2deg);\n    border-radius: 1px;\n  }\n\n  /* Paper fold crease - more subtle */\n  .crease-v {\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    left: 48%;\n    width: 30px;\n    transform: translateX(-50%);\n    background: linear-gradient(to right, transparent 0%, rgba(58, 44, 92, 0.0) 40%, rgba(58, 44, 92, 0.08) 50%, rgba(58, 44, 92, 0.0) 60%, transparent 100%);\n    pointer-events: none;\n    z-index: 5;\n  }\n  .crease-v::after {\n    content: \"\";\n    position: absolute;\n    left: 50%;\n    top: 0;\n    bottom: 0;\n    width: 1px;\n    background: repeating-linear-gradient(to bottom, rgba(58, 44, 92, 0.12) 0 6px, transparent 6px 12px);\n  }\n\n  .font-display {\n    font-family: 'Fraunces', serif;\n  }\n\n  .widget-outer {\n    width: 148px;\n    height: 148px;\n    filter: drop-shadow(0 4px 10px rgba(58, 44, 92, 0.2)) drop-shadow(0 1px 2px rgba(58, 44, 92, 0.15));\n  }\n\n  .widget-inner {\n    width: 100%;\n    height: 100%;\n    /* Subtle inner stroke simulation via shadow */\n    box-shadow: inset 0 0 0 1.5px var(--ink);\n  }\n\n  /* Fade mask for text instead of truncation */\n  .fade-text {\n    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);\n    mask-image: linear-gradient(to right, black 85%, transparent 100%);\n  }\n</style>\n\n<div class=\"widget-outer relative\" data-kid=\"1\">\n  <div class=\"widget-inner paper grain cut-card flex flex-col justify-center relative overflow-hidden\" data-kid=\"2\">\n    \n    <div class=\"crease-v\" data-kid=\"3\"></div>\n\n    \n    <div class=\"absolute top-3 right-3 opacity-25 rotate-12\" data-kid=\"4\">\n      <svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"var(--ink)\" data-kid=\"5\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\" data-kid=\"6\"></path></svg>\n    </div>\n\n    <div class=\"relative z-10 flex flex-col gap-2.5 px-3\" data-kid=\"7\">\n      \n      <div class=\"text-[10px] text-[var(--ink)]/40 font-medium tracking-tight whitespace-nowrap fade-text pl-1\" data-kid=\"8\">\n        the stars were just pinpricks...\n      </div>\n\n      \n      <div class=\"relative py-2 group\" data-kid=\"9\">\n        <div class=\"absolute -inset-x-8 inset-y-0 washi z-0\" data-kid=\"10\"></div>\n        <div class=\"relative z-10 text-[14px] font-black text-[var(--ink)] font-display italic leading-[1.05] px-1 -rotate-[0.5deg]\" data-kid=\"11\">\n          In the velvet dark of a midsummer night\n        </div>\n      </div>\n\n      \n      <div class=\"text-[10px] text-[var(--ink)]/40 font-medium tracking-tight whitespace-nowrap fade-text pl-1\" data-kid=\"12\">\n        we found a path made of silver...\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-3.5 left-4 right-4 flex justify-between items-center z-10\" data-kid=\"13\">\n      <div class=\"text-[8px] uppercase tracking-[0.3em] font-black text-[var(--ink)]/35 font-display italic\" data-kid=\"14\">\n        Lyrico IV\n      </div>\n      <div class=\"text-[8px] font-bold text-[var(--pumpkin)] opacity-80 flex items-center gap-1\" data-kid=\"15\">\n        <span class=\"w-1 h-1 rounded-full bg-[var(--crimson)]\" data-kid=\"16\"></span>\n        02:45\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-0 left-0 right-0 h-2 bg-gradient-to-t from-[var(--ink)]/5 to-transparent\" data-kid=\"17\"></div>\n  </div>\n</div>\n",
