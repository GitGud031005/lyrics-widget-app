      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --cream: #F4E9D0;\n    --cream-2: #EFE0BE;\n    --ink: #3A2C5C;\n    --pumpkin: #E08244;\n    --mint: #A8D6B8;\n    --crimson: #C23D3D;\n  }\n\n  body {\n    background-color: #E2D7C0; /* Page background behind the paper screen */\n    margin: 0;\n    display: flex;\n    justify-content: center;\n    align-items: flex-start;\n    min-height: 100vh;\n    font-family: 'Inter', sans-serif;\n  }\n\n  .paper-screen {\n    width: 375px;\n    background-color: var(--cream);\n    background-image:\n      radial-gradient(rgba(58, 44, 92, 0.04) 1px, transparent 1px),\n      radial-gradient(rgba(192, 140, 80, 0.06) 1px, transparent 1px);\n    background-size: 20px 20px, 6px 6px;\n    background-position: 0 0, 3px 3px;\n    min-height: 100vh;\n    box-shadow: 0 0 50px rgba(0,0,0,0.1);\n    position: relative;\n    overflow-x: clip;\n  }\n\n  .grain::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: .25;\n    mix-blend-mode: multiply;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  .font-display { font-family: 'Fraunces', serif; font-optical-sizing: auto; }\n  .italic-d { font-family: 'Fraunces', serif; font-style: italic; }\n\n  /* Paper cut effects */\n  .cut-card {\n    clip-path: polygon(1% 2%, 8% 0%, 22% 3%, 45% 1%, 70% 2%, 88% 0%, 99% 3%, 100% 18%, 98% 40%, 100% 62%, 99% 82%, 100% 97%, 84% 100%, 60% 98%, 36% 100%, 14% 99%, 2% 100%, 0% 80%, 2% 55%, 0% 30%, 1% 12%);\n  }\n\n  .washi {\n    position: relative;\n    height: 28px;\n    background: repeating-linear-gradient(45deg, rgba(224, 130, 68, .7) 0 8px, rgba(224, 130, 68, .5) 8px 16px);\n    box-shadow: 0 3px 8px rgba(58, 44, 92, 0.15);\n    display: inline-flex;\n    align-items: center;\n    padding: 0 18px;\n    font-size: 11px;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n    font-weight: 800;\n    color: var(--ink);\n    -webkit-mask-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 24' preserveAspectRatio='none'><path d='M0,0 L100,0 L100,4 L98,8 L100,12 L98,16 L100,20 L100,24 L0,24 L0,20 L2,16 L0,12 L2,8 L0,4 Z' fill='black'/></svg>\");\n    mask-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 24' preserveAspectRatio='none'><path d='M0,0 L100,0 L100,4 L98,8 L100,12 L98,16 L100,20 L100,24 L0,24 L0,20 L2,16 L0,12 L2,8 L0,4 Z' fill='black'/></svg>\");\n    -webkit-mask-size: 100% 100%; mask-size: 100% 100%;\n  }\n\n  .cloud-layered {\n    position: absolute;\n    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.05));\n  }\n\n  .pumpkin-slider {\n    -webkit-appearance: none;\n    width: 100%;\n    height: 4px;\n    background: rgba(58, 44, 92, 0.15);\n    border-radius: 4px;\n    outline: none;\n    position: relative;\n  }\n\n  .pumpkin-slider::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    width: 18px;\n    height: 18px;\n    background: var(--pumpkin);\n    border: 2px solid var(--ink);\n    border-radius: 50%;\n    cursor: pointer;\n    box-shadow: 3px 3px 0 var(--ink);\n    margin-top: -7px;\n  }\n\n  .pumpkin-slider::-webkit-slider-runnable-track {\n    width: 100%;\n    height: 4px;\n    cursor: pointer;\n    border-radius: 4px;\n  }\n\n  .toggle-checkbox {\n    display: none;\n  }\n\n  .toggle-label {\n    width: 44px;\n    height: 22px;\n    background: var(--cream-2);\n    border: 2px solid var(--ink);\n    border-radius: 20px;\n    position: relative;\n    cursor: pointer;\n    transition: background 0.3s;\n  }\n\n  .toggle-dot {\n    width: 14px;\n    height: 14px;\n    background: var(--ink);\n    border-radius: 50%;\n    position: absolute;\n    top: 2px;\n    left: 2px;\n    transition: transform 0.3s;\n  }\n\n  .toggle-checkbox:checked + .toggle-label {\n    background: var(--pumpkin);\n  }\n\n  .toggle-checkbox:checked + .toggle-label .toggle-dot {\n    transform: translateX(22px);\n    background: var(--cream);\n  }\n\n  .no-scrollbar::-webkit-scrollbar { display: none; }\n  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .star-deco { color: var(--pumpkin); opacity: 0.6; pointer-events: none; }\n  .scrap { position: absolute; background: var(--cream-2); border: 1px solid var(--ink); opacity: 0.4; pointer-events: none; }\n\n  .flap-card {\n    background: var(--cream);\n    border: 2px solid var(--ink);\n    box-shadow: 6px 6px 0 var(--ink);\n    transition: transform 0.2s, box-shadow 0.2s;\n    transform-origin: center center;\n  }\n\n  .flap-card:active {\n    transform: translate(2px, 2px);\n    box-shadow: 0px 0px 0 var(--ink);\n  }\n\n  .flap-card.selected {\n    border-color: var(--pumpkin);\n    box-shadow: 4px 4px 0 var(--pumpkin);\n  }\n\n  /* GSAP entrance helpers */\n  .section-reveal {\n    opacity: 0;\n  }\n\n</style>\n\n<div class=\"paper-screen grain\" data-kid=\"1\">\n  \n  <header class=\"relative z-20 px-6 pt-10 pb-6 flex items-center justify-between\" data-kid=\"2\">\n    <div class=\"section-reveal\" data-kid=\"3\">\n      <h1 class=\"font-display text-4xl font-black italic text-[var(--ink)] -rotate-1 tracking-tighter\" data-kid=\"4\">Lyrico</h1>\n      <p class=\"text-[10px] uppercase tracking-[0.4em] font-black text-[var(--ink)]/40 mt-1\" data-kid=\"5\">settings &amp; tokens</p>\n    </div>\n    <div class=\"section-reveal\" data-kid=\"6\">\n      <button class=\"w-11 h-11 bg-[var(--cream-2)] border-2 border-[var(--ink)] rounded-2xl flex items-center justify-center shadow-[3px_3px_0_var(--ink)] hover:bg-white active:translate-y-0.5 active:shadow-none transition-all\" data-kid=\"7\">\n        <i class=\"ti ti-history text-xl text-[var(--ink)]\" data-kid=\"8\"></i>\n      </button>\n    </div>\n  </header>\n\n  \n  <section class=\"section-reveal px-6 mb-10 relative\" data-kid=\"9\">\n    <div class=\"flex items-center gap-2 mb-4\" data-kid=\"10\">\n      <span class=\"text-[10px] uppercase tracking-[0.25em] font-black text-[var(--ink)] opacity-70\" data-kid=\"11\">Live Preview</span>\n      <div class=\"h-0.5 flex-1 bg-[var(--ink)] opacity-10\" data-kid=\"12\"></div>\n    </div>\n\n    \n    <div class=\"relative w-full aspect-[4/5] bg-[#9FCBDC] rounded-[48px] border-[3px] border-[var(--ink)] overflow-hidden shadow-2xl\" data-kid=\"13\">\n      \n      <svg class=\"cloud-layered top-[-40px] left-[-20px] w-[240px]\" viewBox=\"0 0 200 100\" fill=\"#B9DBE8\" data-kid=\"14\">\n        <path d=\"M0,100 C0,100 0,60 40,50 C60,45 80,60 100,40 C120,20 160,20 200,60 L200,100 Z\" data-kid=\"15\"></path>\n      </svg>\n      <svg class=\"cloud-layered top-10 right-[-30px] w-[220px] opacity-80\" viewBox=\"0 0 200 100\" fill=\"#D3EBF4\" data-kid=\"16\">\n        <path d=\"M0,100 C20,70 60,60 100,75 C140,90 180,60 200,80 L200,100 Z\" data-kid=\"17\"></path>\n      </svg>\n      <svg class=\"cloud-layered bottom-[-20px] left-[-50px] w-[300px]\" viewBox=\"0 0 200 100\" fill=\"#E8F4F8\" data-kid=\"18\">\n        <path d=\"M0,50 C40,30 80,80 120,60 C160,40 200,70 200,70 L200,100 L0,100 Z\" data-kid=\"19\"></path>\n      </svg>\n\n      \n      <div class=\"absolute inset-0 flex flex-col items-center justify-center p-8\" data-kid=\"20\">\n        <div class=\"w-full bg-[var(--cream)] border-[2.5px] border-[var(--ink)] rounded-[32px] p-5 shadow-[15px_15px_0_rgba(58,44,92,0.12)] relative\" data-kid=\"21\">\n          <div class=\"absolute -top-3 -right-2 washi h-6 text-[8px] rotate-3 scale-75 whitespace-nowrap min-w-max\" data-kid=\"22\">Syncing...</div>\n          \n          <div class=\"flex items-center justify-between mb-4\" data-kid=\"23\">\n            <div class=\"flex items-center gap-2\" data-kid=\"24\">\n              <div class=\"w-2 h-2 rounded-full bg-[var(--pumpkin)]\" data-kid=\"25\"></div>\n              <span class=\"text-[9px] font-black uppercase tracking-wider opacity-60\" data-kid=\"26\">Dancing in the Dark</span>\n            </div>\n            <i class=\"ti ti-music text-[var(--ink)] text-xs\" data-kid=\"27\"></i>\n          </div>\n\n          <div class=\"space-y-2\" data-kid=\"28\">\n            <div class=\"text-[11px] font-medium opacity-30 leading-tight\" data-kid=\"29\">Message in a bottle...</div>\n            <div class=\"bg-[var(--pumpkin)]/15 border-l-3 border-[var(--pumpkin)] py-1.5 px-3 rounded-r-lg\" data-kid=\"30\">\n              <span class=\"text-sm font-display font-black leading-tight text-[var(--ink)] italic-d\" data-kid=\"31\">I'm just a soul whose intentions are good...</span>\n            </div>\n            <div class=\"text-[11px] font-medium opacity-30 leading-tight\" data-kid=\"32\">Oh lord, please don't let me be misunderstood...</div>\n          </div>\n\n          \n          <div class=\"mt-5 flex items-center justify-center gap-5\" data-kid=\"33\">\n            <button class=\"w-8 h-8 rounded-full border-2 border-[var(--ink)] flex items-center justify-center text-[var(--ink)] bg-[var(--cream-2)]\" data-kid=\"34\"><i class=\"ti ti-player-skip-back text-xs\" data-kid=\"35\"></i></button>\n            <button class=\"w-10 h-10 rounded-full border-2 border-[var(--ink)] flex items-center justify-center text-white bg-[var(--ink)] shadow-[2px_2px_0_var(--pumpkin)]\" data-kid=\"36\"><i class=\"ti ti-player-play text-sm\" data-kid=\"37\"></i></button>\n            <button class=\"w-8 h-8 rounded-full border-2 border-[var(--ink)] flex items-center justify-center text-[var(--ink)] bg-[var(--cream-2)]\" data-kid=\"38\"><i class=\"ti ti-player-skip-forward text-xs\" data-kid=\"39\"></i></button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-4 p-3 bg-white/20 backdrop-blur-xl border border-white/30 rounded-[24px]\" data-kid=\"40\">\n        <div class=\"w-8 h-8 bg-white/40 rounded-xl\" data-kid=\"41\"></div>\n        <div class=\"w-8 h-8 bg-white/40 rounded-xl\" data-kid=\"42\"></div>\n        <div class=\"w-8 h-8 bg-white/40 rounded-xl\" data-kid=\"43\"></div>\n        <div class=\"w-8 h-8 bg-white/40 rounded-xl\" data-kid=\"44\"></div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section-reveal px-6 mb-10\" data-kid=\"45\">\n    <div class=\"flex items-center gap-2 mb-5\" data-kid=\"46\">\n      <span class=\"text-[10px] uppercase tracking-[0.25em] font-black text-[var(--ink)] opacity-70\" data-kid=\"47\">Style Presets</span>\n    </div>\n    \n    <div class=\"flex gap-4 overflow-x-auto pb-6 no-scrollbar pr-6\" data-kid=\"48\">\n      \n      <div class=\"shrink-0 w-[115px] flap-card p-4 rounded-xl rotate-[-2deg] selected\" data-kid=\"49\">\n        <div class=\"text-[10px] font-black uppercase tracking-widest mb-3 truncate\" data-kid=\"50\">Classic</div>\n        <div class=\"space-y-1.5 opacity-60\" data-kid=\"51\">\n          <div class=\"h-1.5 w-full bg-[var(--ink)] rounded-full opacity-20\" data-kid=\"52\"></div>\n          <div class=\"h-1.5 w-4/5 bg-[var(--ink)] rounded-full\" data-kid=\"53\"></div>\n          <div class=\"h-1.5 w-full bg-[var(--ink)] rounded-full opacity-20\" data-kid=\"54\"></div>\n        </div>\n        <div class=\"mt-4 flex justify-end\" data-kid=\"55\">\n           <i class=\"ti ti-circle-check-filled text-[var(--pumpkin)]\" data-kid=\"56\"></i>\n        </div>\n      </div>\n\n      \n      <div class=\"shrink-0 w-[115px] flap-card p-4 rounded-xl rotate-[1deg]\" style=\"background: var(--mint);\" data-kid=\"57\">\n        <div class=\"text-[10px] font-black uppercase tracking-widest mb-3 truncate\" data-kid=\"58\">Botanical</div>\n        <div class=\"space-y-1.5 opacity-60\" data-kid=\"59\">\n          <div class=\"h-1.5 w-full bg-[var(--ink)] rounded-full opacity-20\" data-kid=\"60\"></div>\n          <div class=\"h-1.5 w-full bg-[var(--ink)] rounded-full\" data-kid=\"61\"></div>\n          <div class=\"h-1.5 w-2/3 bg-[var(--ink)] rounded-full opacity-20\" data-kid=\"62\"></div>\n        </div>\n        <div class=\"mt-4 flex justify-end\" data-kid=\"63\">\n           <div class=\"w-4 h-4 rounded-full border border-[var(--ink)] opacity-30\" data-kid=\"64\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"shrink-0 w-[115px] flap-card p-4 rounded-xl rotate-[-1deg]\" style=\"background: var(--ink); color: var(--cream);\" data-kid=\"65\">\n        <div class=\"text-[10px] font-black uppercase tracking-wider mb-3 opacity-90 truncate\" data-kid=\"66\">Nocturnal</div>\n        <div class=\"space-y-1.5 opacity-40\" data-kid=\"67\">\n          <div class=\"h-1.5 w-full bg-[var(--cream)] rounded-full\" data-kid=\"68\"></div>\n          <div class=\"h-1.5 w-3/4 bg-[var(--cream)] rounded-full\" data-kid=\"69\"></div>\n          <div class=\"h-1.5 w-full bg-[var(--cream)] rounded-full\" data-kid=\"70\"></div>\n        </div>\n        <div class=\"mt-4 flex justify-end\" data-kid=\"71\">\n           <div class=\"w-4 h-4 rounded-full border border-[var(--cream)] opacity-30\" data-kid=\"72\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section-reveal px-6 mb-12 space-y-10\" data-kid=\"73\">\n    \n    <div class=\"space-y-4\" data-kid=\"74\">\n      <div class=\"flex justify-between items-end\" data-kid=\"75\">\n        <div data-kid=\"76\">\n          <h3 class=\"text-[14px] font-black text-[var(--ink)] uppercase tracking-[0.1em]\" data-kid=\"77\">Font Scaling</h3>\n          <p class=\"text-[11px] text-[var(--ink)]/40 italic font-semibold\" data-kid=\"78\">Adjust for readability</p>\n        </div>\n        <span class=\"text-sm font-display font-black italic text-[var(--pumpkin)] underline decoration-2 underline-offset-4\" data-kid=\"79\">14px</span>\n      </div>\n      <div class=\"relative pt-2\" data-kid=\"80\">\n        <input type=\"range\" class=\"pumpkin-slider\" min=\"10\" max=\"24\" value=\"14\" data-kid=\"81\">\n        <div class=\"absolute -bottom-6 left-0 text-[9px] font-black opacity-50\" data-kid=\"82\">10px</div>\n        <div class=\"absolute -bottom-6 right-0 text-[9px] font-black opacity-50\" data-kid=\"83\">24px</div>\n      </div>\n    </div>\n\n    \n    <div class=\"space-y-4 pt-4\" data-kid=\"84\">\n      <div class=\"flex justify-between items-end\" data-kid=\"85\">\n        <div data-kid=\"86\">\n          <h3 class=\"text-[14px] font-black text-[var(--ink)] uppercase tracking-[0.1em]\" data-kid=\"87\">Line Capacity</h3>\n          <p class=\"text-[11px] text-[var(--ink)]/40 italic font-semibold\" data-kid=\"88\">Visible context lines</p>\n        </div>\n        <span class=\"text-sm font-display font-black italic text-[var(--pumpkin)] underline decoration-2 underline-offset-4\" data-kid=\"89\">3 lines</span>\n      </div>\n      <div class=\"relative pt-2\" data-kid=\"90\">\n        <input type=\"range\" class=\"pumpkin-slider\" min=\"1\" max=\"5\" value=\"3\" data-kid=\"91\">\n        <div class=\"absolute -bottom-6 left-0 text-[9px] font-black opacity-50\" data-kid=\"92\">1</div>\n        <div class=\"absolute -bottom-6 right-0 text-[9px] font-black opacity-50\" data-kid=\"93\">5</div>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 gap-5 pt-4\" data-kid=\"94\">\n      <div class=\"flex items-center justify-between p-4 bg-[var(--cream-2)] border-2 border-[var(--ink)] rounded-2xl shadow-[5px_5px_0_var(--ink)]\" data-kid=\"95\">\n        <div class=\"flex items-center gap-4\" data-kid=\"96\">\n          <div class=\"w-11 h-11 rounded-xl bg-[var(--pumpkin)] border-2 border-[var(--ink)] flex items-center justify-center shadow-[3px_3px_0_var(--ink)]\" data-kid=\"97\">\n            <i class=\"ti ti-typography text-2xl text-[var(--ink)]\" data-kid=\"98\"></i>\n          </div>\n          <div data-kid=\"99\">\n            <span class=\"block text-[13px] font-black text-[var(--ink)] leading-none mb-1\" data-kid=\"100\">High Contrast</span>\n            <span class=\"text-[11px] text-[var(--ink)]/40 font-semibold italic\" data-kid=\"101\">Sharper text rendering</span>\n          </div>\n        </div>\n        <label class=\"relative inline-flex items-center cursor-pointer\" data-kid=\"102\">\n          <input type=\"checkbox\" class=\"toggle-checkbox\" checked data-kid=\"103\">\n          <div class=\"toggle-label\" data-kid=\"104\">\n            <div class=\"toggle-dot\" data-kid=\"105\"></div>\n          </div>\n        </label>\n      </div>\n\n      <div class=\"flex items-center justify-between p-4 bg-[var(--cream-2)] border-2 border-[var(--ink)] rounded-2xl shadow-[5px_5px_0_var(--ink)]\" data-kid=\"106\">\n        <div class=\"flex items-center gap-4\" data-kid=\"107\">\n          <div class=\"w-11 h-11 rounded-xl bg-[var(--mint)] border-2 border-[var(--ink)] flex items-center justify-center shadow-[3px_3px_0_var(--ink)]\" data-kid=\"108\">\n            <i class=\"ti ti-brand-apple text-2xl text-[var(--ink)]\" data-kid=\"109\"></i>\n          </div>\n          <div data-kid=\"110\">\n            <span class=\"block text-[13px] font-black text-[var(--ink)] leading-none mb-1\" data-kid=\"111\">iOS Aesthetics</span>\n            <span class=\"text-[11px] text-[var(--ink)]/40 font-semibold italic\" data-kid=\"112\">Use system-style blur</span>\n          </div>\n        </div>\n        <label class=\"relative inline-flex items-center cursor-pointer\" data-kid=\"113\">\n          <input type=\"checkbox\" class=\"toggle-checkbox\" data-kid=\"114\">\n          <div class=\"toggle-label\" data-kid=\"115\">\n            <div class=\"toggle-dot\" data-kid=\"116\"></div>\n          </div>\n        </label>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"px-6 pb-16 flex flex-col items-center\" data-kid=\"117\">\n    <div class=\"h-px w-full bg-[var(--ink)] opacity-10 mb-10\" data-kid=\"118\"></div>\n    <div class=\"washi rotate-[-1deg] relative\" data-kid=\"119\">\n      <i class=\"ti ti-plug-connected-filled mr-2 text-[var(--ink)]\" data-kid=\"120\"></i>\n      App Group Verified\n      <div class=\"absolute -top-1 -right-1 w-2.5 h-2.5 bg-[#4CAF50] rounded-full border border-[var(--ink)]\" data-kid=\"121\"></div>\n    </div>\n    <p class=\"mt-8 text-[11px] font-display italic text-[var(--ink)]/50\" data-kid=\"122\">— handcrafted for shared state —</p>\n  </footer>\n\n  \n  <i class=\"ti ti-star-filled star-deco absolute top-24 right-4 text-xs\" data-kid=\"123\"></i>\n  <i class=\"ti ti-star-filled star-deco absolute bottom-48 left-3 text-[10px]\" data-kid=\"124\"></i>\n  <i class=\"ti ti-sparkles star-deco absolute top-[42%] right-6 text-sm\" data-kid=\"125\"></i>\n  <div class=\"scrap w-3 h-3 rotate-12 top-12 left-10 rounded-xs\" data-kid=\"126\"></div>\n  <div class=\"scrap w-2 h-4 -rotate-12 bottom-20 right-10 rounded-xs\" data-kid=\"127\"></div>\n  <div class=\"scrap w-4 h-1 rotate-45 top-[60%] left-4 rounded-full opacity-20\" data-kid=\"128\"></div>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"129\"></script>\n<script data-kid=\"130\">\n  // Entrance Animations\n  document.addEventListener('DOMContentLoaded', () => {\n    // Correct GSAP fromTo syntax to avoid FOUC and syntax errors\n    gsap.fromTo('.section-reveal', \n      { opacity: 0, y: 30 },\n      { opacity: 1, y: 0, stagger: 0.1, duration: 0.8, ease: \"power2.out\" }\n    );\n\n    // Animate sliders to their values\n    gsap.from('.pumpkin-slider', {\n      scaleX: 0,\n      duration: 1.2,\n      delay: 0.5,\n      stagger: 0.2,\n      transformOrigin: \"left center\"\n    });\n\n    // Washi tape appearance\n    gsap.from('.washi', {\n      scaleX: 0.8,\n      opacity: 0,\n      duration: 0.8,\n      delay: 1.2,\n      ease: \"back.out(1.7)\"\n    });\n    \n    gsap.from('.scrap', {\n      opacity: 0,\n      scale: 0,\n      rotate: 0,\n      stagger: 0.2,\n      duration: 1,\n      delay: 1.5,\n      ease: \"elastic.out(1, 0.5)\"\n    });\n  });\n</script>\n",
