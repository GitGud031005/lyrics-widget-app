      "html": "\n<div class=\"paper-app min-h-screen w-[375px] mx-auto bg-[#F4E9D0] font-sans text-[#3A2C5C] overflow-hidden relative selection:bg-[#E08244]/30\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&family=Inter:wght@400;500;600;700&display=swap');\n\n        :root {\n            --cream: #F4E9D0;\n            --ink: #3A2C5C;\n            --pumpkin: #E08244;\n            --mint: #A8D6B8;\n            --crimson: #C23D3D;\n        }\n\n        .paper-grain {\n            background-image: \n                radial-gradient(rgba(58, 44, 92, 0.05) 1px, transparent 1px),\n                radial-gradient(rgba(224, 130, 68, 0.05) 1px, transparent 1px);\n            background-size: 24px 24px, 12px 12px;\n            pointer-events: none;\n        }\n\n        .hand-cut-paper {\n            clip-path: polygon(\n                1% 2%, 18% 0%, 36% 3%, 55% 1%, 78% 2%, 99% 0%, \n                100% 22%, 98% 48%, 100% 74%, 99% 98%, \n                82% 100%, 61% 97%, 42% 100%, 15% 98%, 2% 100%, \n                0% 72%, 3% 45%, 0% 18%\n            );\n        }\n\n        .washi-tape {\n            background: repeating-linear-gradient(45deg, rgba(224, 130, 68, 0.2), rgba(224, 130, 68, 0.2) 12px, rgba(224, 130, 68, 0.35) 12px, rgba(224, 130, 68, 0.35) 24px);\n            border-left: 1px dashed rgba(58, 44, 92, 0.3);\n            border-right: 1px dashed rgba(58, 44, 92, 0.3);\n            filter: drop-shadow(1px 2px 3px rgba(0,0,0,0.1));\n            -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);\n            mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);\n        }\n\n        .fox-sticker-cut {\n            clip-path: polygon(10% 0, 90% 0, 100% 10%, 100% 90%, 90% 100%, 10% 100%, 0 90%, 0 10%);\n        }\n\n        .cut-button-shape {\n            clip-path: polygon(\n                3% 0%, 97% 0%, 100% 20%, 98% 50%, 100% 80%, 97% 100%, 3% 100%, 0% 80%, 2% 50%, 0% 20%\n            );\n        }\n\n        .dotted-divider {\n            background-image: radial-gradient(circle, var(--ink) 1.5px, transparent 1.5px);\n            background-size: 10px 10px;\n            background-repeat: repeat-x;\n            height: 10px;\n            opacity: 0.2;\n        }\n\n        .crease-v {\n            background: linear-gradient(to right, transparent, rgba(58, 44, 92, 0.1) 50%, transparent);\n            width: 2px;\n            height: 100%;\n        }\n\n        .fox-shadow {\n            filter: drop-shadow(4px 4px 0px var(--ink));\n        }\n\n        .ink-stamp {\n            mask-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='100' height='100' viewBox='0 0 100 100'><circle cx='50' cy='50' r='40' fill='black' fill-opacity='0.4'/></svg>\");\n            mask-size: contain;\n            opacity: 0.08;\n        }\n\n        .scallop-edge {\n            mask-image: radial-gradient(circle 10px at 10px 0, transparent 9px, black 10px);\n            mask-size: 20px 100%;\n            mask-repeat: repeat-x;\n        }\n    </style>\n\n    \n    <div class=\"absolute inset-0 paper-grain z-0\" data-kid=\"2\"></div>\n    \n    \n    <div class=\"absolute top-20 right-4 w-12 h-12 bg-[var(--ink)] ink-stamp rotate-12 z-0\" data-kid=\"3\"></div>\n    <div class=\"absolute bottom-40 left-2 w-16 h-16 bg-[var(--pumpkin)] ink-stamp -rotate-6 z-0\" data-kid=\"4\"></div>\n\n    \n    <div class=\"relative z-10 px-6 pt-12 pb-8 flex flex-col min-h-screen\" data-kid=\"5\">\n        \n        \n        <header class=\"mb-10 animate-header\" data-kid=\"6\">\n            <div class=\"flex justify-between items-center mb-6\" data-kid=\"7\">\n                <div class=\"bg-[var(--mint)] border-2 border-[var(--ink)] px-3 py-1 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_var(--ink)] rotate-[-1.5deg]\" data-kid=\"8\">\n                    Folio Archive\n                </div>\n                <div class=\"flex gap-2 -rotate-12\" data-kid=\"9\">\n                    <div class=\"w-3 h-3 rounded-full bg-[var(--crimson)] border-2 border-[var(--ink)] shadow-[1px 1px 0 var(--ink)]\" data-kid=\"10\"></div>\n                    <div class=\"w-3 h-3 rounded-full bg-[var(--pumpkin)] border-2 border-[var(--ink)] shadow-[1px 1px 0 var(--ink)]\" data-kid=\"11\"></div>\n                    <div class=\"w-3 h-3 rounded-full bg-[var(--ink)]/20 border-2 border-[var(--ink)]/30\" data-kid=\"12\"></div>\n                </div>\n            </div>\n\n            <h1 class=\"font-['Fraunces'] text-[48px] font-black leading-[0.9] text-[var(--ink)] mb-1 tracking-tight\" data-kid=\"13\">\n                Gold Rush\n            </h1>\n            <p class=\"font-['Fraunces'] italic text-xl text-[var(--ink)]/80 mb-5\" data-kid=\"14\">Taylor Swift</p>\n            \n            <div class=\"dotted-divider w-full mb-5\" data-kid=\"15\"></div>\n            \n            <div class=\"flex flex-wrap items-center gap-y-2 gap-x-6\" data-kid=\"16\">\n                <div class=\"flex items-center gap-2\" data-kid=\"17\">\n                    <span class=\"text-[10px] font-bold text-[var(--pumpkin)] uppercase tracking-wider\" data-kid=\"18\">Album</span>\n                    <span class=\"text-xs font-medium border-b-2 border-[var(--pumpkin)]/30\" data-kid=\"19\">Evermore</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"20\">\n                    <span class=\"text-[10px] font-bold text-[var(--pumpkin)] uppercase tracking-wider\" data-kid=\"21\">Type</span>\n                    <span class=\"text-xs font-medium italic font-['Fraunces']\" data-kid=\"22\">Synced</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"23\">\n                    <span class=\"text-[10px] font-bold text-[var(--pumpkin)] uppercase tracking-wider\" data-kid=\"24\">Dur</span>\n                    <span class=\"text-xs font-medium\" data-kid=\"25\">3:05</span>\n                </div>\n            </div>\n        </header>\n\n        \n        <main class=\"relative flex-1 mb-8\" data-kid=\"26\">\n            \n            <div class=\"absolute inset-0 bg-[var(--ink)]/10 hand-cut-paper translate-x-2 translate-y-3 blur-[2px]\" data-kid=\"27\"></div>\n            \n            \n            <div class=\"lyric-card relative bg-white min-h-[460px] hand-cut-paper p-8 flex flex-col justify-center overflow-hidden border-2 border-[var(--ink)]/5\" data-kid=\"28\">\n                \n                <div class=\"absolute left-1/2 top-0 bottom-0 crease-v opacity-40\" data-kid=\"29\"></div>\n                \n                \n                <div class=\"space-y-12 relative z-10 py-10\" data-kid=\"30\">\n                    \n                    <div class=\"lyric-line flex gap-3 items-start opacity-45\" data-kid=\"31\">\n                        <span class=\"text-[10px] mt-1 font-mono font-bold tracking-tighter shrink-0\" data-kid=\"32\">0:12</span>\n                        <p class=\"font-['Fraunces'] text-xl italic leading-snug\" data-kid=\"33\">Gleaming, twinkling</p>\n                    </div>\n                    \n                    \n                    <div class=\"lyric-line active-line relative group\" data-kid=\"34\">\n                        \n                        <div class=\"washi-tape-highlight absolute -inset-x-8 -inset-y-4 washi-tape rotate-[0.5deg] opacity-0\" data-kid=\"35\"></div>\n                        <div class=\"flex gap-3 items-start relative py-1\" data-kid=\"36\">\n                            <span class=\"text-[10px] mt-2 font-mono font-black text-[var(--pumpkin)] shrink-0\" data-kid=\"37\">0:16</span>\n                            <p class=\"font-['Fraunces'] text-[26px] font-black leading-[1.05] text-[var(--ink)] [text-shadow:0_0_10px_rgba(255,255,255,0.4)]\" data-kid=\"38\">Eyes like sinking ships on waters so inviting</p>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"lyric-line flex gap-3 items-start opacity-45\" data-kid=\"39\">\n                        <span class=\"text-[10px] mt-1 font-mono font-bold tracking-tighter shrink-0\" data-kid=\"40\">0:21</span>\n                        <p class=\"font-['Fraunces'] text-xl italic leading-snug\" data-kid=\"41\">I almost jump in</p>\n                    </div>\n\n                    \n                    <div class=\"lyric-line flex gap-3 items-start opacity-45\" data-kid=\"42\">\n                        <span class=\"text-[10px] mt-1 font-mono font-bold tracking-tighter shrink-0\" data-kid=\"43\">0:24</span>\n                        <p class=\"font-['Fraunces'] text-xl italic leading-snug\" data-kid=\"44\">But I don't like a gold rush</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-3 opacity-30\" data-kid=\"45\">\n                    <span class=\"text-[9px] font-['Fraunces'] italic tracking-widest uppercase\" data-kid=\"46\">Folio 1.0</span>\n                    <div class=\"h-[1px] w-4 bg-[var(--ink)]\" data-kid=\"47\"></div>\n                    <span class=\"text-[9px] font-mono tracking-tighter\" data-kid=\"48\">P. 104</span>\n                </div>\n\n                \n                <div class=\"fox-container absolute -bottom-10 -right-4 w-40 h-40 rotate-[8deg]\" data-kid=\"49\">\n                    <div class=\"relative w-full h-full\" data-kid=\"50\">\n                        \n                        <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-12 h-4 bg-[var(--mint)] opacity-60 rotate-[5deg] z-20 border-x border-dashed border-[var(--ink)]/20\" data-kid=\"51\"></div>\n                        \n                        <div class=\"absolute inset-0 bg-[var(--ink)]/20 rounded-full blur-md translate-y-4 translate-x-4\" data-kid=\"52\"></div>\n                        <div class=\"relative w-full h-full fox-sticker-cut overflow-hidden border-4 border-white shadow-xl\" data-kid=\"53\">\n                            <img src=\"https://kombai-assets.b-cdn.net/generated_assets/546bcd6a-ae6d-45c1-85a6-b370c2cc2f99/7faea13a823a42299a4a3a537ac4b85b.jpg\" class=\"w-full h-full object-cover\" alt=\"Melodic Fox\" decoding=\"async\" loading=\"lazy\" data-kid=\"54\">\n                        </div>\n                        \n                        <div class=\"absolute top-4 right-4 bg-[var(--crimson)] text-white text-[9px] font-bold px-2 py-0.5 rounded-sm shadow-[3px_3px_0_var(--ink)] rotate-[12deg] z-20\" data-kid=\"55\">PLATE IV</div>\n                    </div>\n                </div>\n            </div>\n        </main>\n\n        \n        <div class=\"cta-container relative animate-cta\" data-kid=\"56\">\n            \n            <div class=\"absolute inset-0 bg-[var(--ink)] translate-x-1.5 translate-y-1.5 cut-button-shape opacity-20\" data-kid=\"57\"></div>\n            \n            <button class=\"w-full relative bg-[var(--pumpkin)] text-white py-5 px-8 flex items-center justify-center gap-3 cut-button-shape border-2 border-[var(--ink)] shadow-lg hover:brightness-110 active:translate-y-1 transition-all\" data-kid=\"58\">\n                <span class=\"font-['Fraunces'] font-black text-2xl tracking-tight relative z-10\" data-kid=\"59\">Set to Widget</span>\n                <i class=\"ti ti-sparkles text-2xl relative z-10\" data-kid=\"60\"></i>\n                \n                \n                <div class=\"absolute bottom-0 left-0 w-full h-1 bg-[var(--ink)]/20 scallop-edge opacity-50\" data-kid=\"61\"></div>\n            </button>\n        </div>\n\n        \n        <footer class=\"mt-8 text-center\" data-kid=\"62\">\n            <div class=\"flex items-center justify-center gap-4 mb-4\" data-kid=\"63\">\n                <div class=\"h-[1px] flex-1 bg-[var(--ink)] opacity-10\" data-kid=\"64\"></div>\n                <div class=\"font-['Fraunces'] italic text-[11px] opacity-40\" data-kid=\"65\">hand-pressed in brooklyn</div>\n                <div class=\"h-[1px] flex-1 bg-[var(--ink)] opacity-10\" data-kid=\"66\"></div>\n            </div>\n        </footer>\n    </div>\n\n    \n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"67\">\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"68\"></script>\n    <script data-kid=\"69\">\n        document.addEventListener('DOMContentLoaded', () => {\n            const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.2 } });\n\n            // Entrance animations\n            tl.from('.animate-header', { y: -30, opacity: 0, duration: 0.8 }, 0.2)\n              .from('.lyric-card', { \n                  scale: 0.95, \n                  y: 40, \n                  rotationX: 20, \n                  opacity: 0, \n                  transformOrigin: 'top center',\n                  duration: 1.5,\n                  ease: 'elastic.out(1, 0.75)'\n              }, 0.4)\n              .from('.lyric-line', { \n                  x: -20, \n                  opacity: 0, \n                  stagger: 0.1, \n                  duration: 0.8 \n              }, 0.8)\n              .to('.washi-tape-highlight', { \n                  opacity: 1, \n                  scaleX: 1.05, \n                  duration: 0.6, \n                  ease: 'back.out(1.7)' \n              }, 1.4)\n              .from('.fox-container', { \n                  scale: 0, \n                  rotation: -30, \n                  duration: 1, \n                  ease: 'back.out(2)' \n              }, 1.2)\n              .from('.animate-cta', { \n                  y: 50, \n                  opacity: 0, \n                  duration: 0.8 \n              }, 1.6);\n              \n            // Subtle floating effect for the fox\n            gsap.to('.fox-container', {\n                y: -5,\n                rotation: 17,\n                repeat: -1,\n                yoyo: true,\n                duration: 3,\n                ease: 'sine.inOut'\n            });\n        });\n    </script>\n</div>\n",
